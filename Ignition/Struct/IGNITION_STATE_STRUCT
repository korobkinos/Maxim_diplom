TYPE IGNITION_STATE_STRUCT :
STRUCT
	in_progress         : BOOL; // bit0  - Запущена процедура розжига запальника
	no_flame            : BOOL; // bit1  - Нет пламени запальника
	success_msg         : BOOL; // bit2  - Успешный розжиг запальника
	reserved_3          : BOOL; // bit3  - резерв
	reserved_4          : BOOL; // bit4  - резерв
	reserved_5          : BOOL; // bit5  - резерв
	reserved_6          : BOOL; // bit6  - резерв
	flame_lost          : BOOL; // bit7  - Погасание пламени запальника
	reserved_8          : BOOL; // bit8  - резерв
	reserved_9          : BOOL; // bit9  - резерв
	reserved_10         : BOOL; // bit10 - резерв
	reserved_11         : BOOL; // bit11 - резерв
	reserved_12         : BOOL; // bit12 - резерв
	reserved_13         : BOOL; // bit13 - резерв
	repeat_msg          : BOOL; // bit14 - Повторный розжиг запальника
	stop_msg            : BOOL; // bit15 - Остановка запальника
	reserved_16         : BOOL; // bit16 - резерв
	reserved_17         : BOOL; // bit17 - резерв
END_STRUCT
END_TYPE