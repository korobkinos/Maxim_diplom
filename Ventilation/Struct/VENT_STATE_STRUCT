TYPE VENT_STATE_STRUCT :
STRUCT
	success                 : BOOL; // bit0  - Вентиляция проведена
	in_progress             : BOOL; // bit1  - Идёт вентиляция
	skipped                 : BOOL; // bit2  - Вентиляция пропущена оператором
	cancelled               : BOOL; // bit3  - Вентиляция отменена оператором
	fan_start_error         : BOOL; // bit4  - Ошибка включения вентилятора
	shiber_open_error       : BOOL; // bit5  - Ошибка открытия шибера
	fan_lost                : BOOL; // bit6  - Вентилятор отключился во время вентиляции
	shiber_reopen           : BOOL; // bit7  - Повторная команда открыть шибер
	timeout_reset           : BOOL; // bit8  - Вентиляция сброшена по таймеру
	reset_done              : BOOL; // bit9  - Вентиляция сброшена оператором
	msg_success             : BOOL; // bit10 - Сообщение "Вентиляция проведена"
	msg_fail                : BOOL; // bit11 - Сообщение "Вентиляция не проведена"
	prestart_success        : BOOL; // bit12 - Предпусковая вентиляция выполнена
	skip_success            : BOOL; // bit13 - Вентиляция пропущена и засчитана
	shiber_close_error      : BOOL; // bit14 - Ошибка закрытия шибера
	post_emergency_success  : BOOL; // bit15 - Послеаварийная вентиляция выполнена
	post_emergency_active   : BOOL; // bit16 - Активна послеаварийная вентиляция
	prestart_active         : BOOL; // bit17 - Активна предпусковая вентиляция
	shiber_init_error		: BOOL; // bit18 - ошибка исходного положения шибера
END_STRUCT
END_TYPE