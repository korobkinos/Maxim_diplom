PROGRAM ARMATURE

VAR
	valves : ARRAY[0..counter_armature] OF valve_universal_singl;

	up_cmd       : ARRAY[0..counter_armature] OF BOOL;
	down_cmd     : ARRAY[0..counter_armature] OF BOOL;
	open_cmd     : ARRAY[0..counter_armature] OF BOOL;
	close_cmd    : ARRAY[0..counter_armature] OF BOOL;
	block_cmd    : ARRAY[0..counter_armature] OF BOOL;

	i,j : BYTE;
END_VAR

// === IMPLEMENTATION ===

(*
========================================================
	1. ПОДГОТОВКА БАЗОВЫХ КОМАНД И РЕЖИМОВ
========================================================
*)
FOR i := 0 TO counter_armature DO
	GVL_VALVE.imitation_mode[i] := SETTINGS.armature_simulation;

	open_cmd[i] := GVL_VALVE.open[i];
	close_cmd[i] := GVL_VALVE.closed[i];
	up_cmd[i] := GVL_VALVE.up[i];
	down_cmd[i] := GVL_VALVE.down[i];
	block_cmd[i] := GVL_VALVE.block[i];
END_FOR;


(*
========================================================
	2. ДОПОЛНИТЕЛЬНЫЕ КОМАНДЫ ОТ ДРУГИХ АЛГОРИТМОВ
========================================================
*)

// Импульс регулятора на открытие газового шибера при выводе на минимальную мощность
up_cmd[gas_shiber] := up_cmd[gas_shiber] OR GVL_REGULATOR.min_power_impulse_up;

// Имитация пламени горелки
open_cmd[pilot] := open_cmd[pilot] OR GVL_SIMULATION.burner_pilot_open;
close_cmd[pilot] := close_cmd[pilot] OR GVL_SIMULATION.burner_pilot_closed;

// Имитация пламени запальника
open_cmd[ignit] := open_cmd[ignit] OR GVL_SIMULATION.ignition_ignit_open;
close_cmd[ignit] := close_cmd[ignit] OR GVL_SIMULATION.ignition_ignit_closed;

// Искра
open_cmd[spark] := open_cmd[spark] OR GVL_IGNITION.spark_SET;
close_cmd[spark] := close_cmd[spark] OR GVL_IGNITION.spark_RESET;

// ПЗК-1
open_cmd[pzk_1] := open_cmd[pzk_1]
	OR GVL_BURNER.PZK_1_SET
	OR GVL_PRESSURE.PZK_1_SET
	OR GVL_IGNITION.PZK_1_SET;

close_cmd[pzk_1] := close_cmd[pzk_1]
	OR GVL_BURNER.PZK_1_RESET
	OR GVL_PRESSURE.PZK_1_RESET;

// ПЗК-2
open_cmd[pzk_2] := open_cmd[pzk_2] OR GVL_BURNER.PZK_2_SET;
close_cmd[pzk_2] := close_cmd[pzk_2] OR GVL_BURNER.PZK_2_RESET;

// Шибер воздуха
open_cmd[air_shiber] := open_cmd[air_shiber]
	OR GVL_BURNER.shiber_open
	OR GVL_VENTILATION.shiber_open;

close_cmd[air_shiber] := close_cmd[air_shiber]
	OR GVL_BURNER.shiber_closed
	OR GVL_VENTILATION.shiber_close;

// Газовый шибер
open_cmd[gas_shiber] := open_cmd[gas_shiber] OR GVL_BURNER.GAZ_shiber_open;
close_cmd[gas_shiber] := close_cmd[gas_shiber] OR GVL_BURNER.GAZ_shiber_closed;

// КЗ
open_cmd[kz] := open_cmd[kz] OR GVL_IGNITION.KZ_SET;
close_cmd[kz] := close_cmd[kz] OR GVL_IGNITION.KZ_RESET;

// Вентилятор горелки
open_cmd[vent_burner] := open_cmd[vent_burner]
	OR GVL_BURNER.ventilator_burner_on
	OR GVL_VENTILATION.fan_on;

close_cmd[vent_burner] := close_cmd[vent_burner]
	OR GVL_BURNER.ventilator_burner_off;

// Клапан безопасности
open_cmd[kb] := open_cmd[kb] OR GVL_PRESSURE.KB_SET;
close_cmd[kb] := close_cmd[kb] OR GVL_PRESSURE.KB_RESET;

// Клапан опрессовки
open_cmd[ko] := open_cmd[ko] OR GVL_PRESSURE.KO_SET;
close_cmd[ko] := close_cmd[ko] OR GVL_PRESSURE.KO_RESET;


(*
========================================================
	3. ВЫЗОВ FB АРМАТУРЫ
========================================================
*)
FOR i := 0 TO counter_armature DO

	valves[i](
		// Команды позиционирования
		up := up_cmd[i] OR GVL_REGULATOR.reg_valve[i].up_out,
		down := down_cmd[i] OR GVL_REGULATOR.reg_valve[i].down_out,
		open := open_cmd[i],
		closed := close_cmd[i],

		// Режимы и блокировки
		stop := GVL_VALVE.stop[i],
		set_special := GVL_VALVE.set_special[i],

		set_auto := GVL_REGULATOR.reg_valve[i].auto_set
			OR GVL_VALVE.set_auto[i],

		set_manual := GVL_VALVE.open[i]
			OR GVL_VALVE.closed[i]
			OR GVL_VALVE.set_manual[i]
			OR GVL_REGULATOR.reg_valve[i].man_set,

		block := block_cmd[i] OR GVL_BLOCKS.valves_blocks[i],

		// Дискретные входы состояния
		open_state_di := GVL_VALVE.open_state_di[i],
		closed_state_di := GVL_VALVE.closed_state_di[i],
		special_state_di := GVL_VALVE.special_state_di[i],

		// Настройки конкретной арматуры
		wait_time := SETTINGS.wait_time_burner[i],
		pull_time := SETTINGS.pull_time[i],
		off_time := SETTINGS.off_time_burner[i],
		one_state := SETTINGS.BURNER_ONE_STATE[i],
		imitation_mode := GVL_VALVE.imitation_mode[i],
		block_mode := SETTINGS.BURNER_BLOCK_MODE[i],

		// Выходы и состояния
		control_out => GVL_VALVE.control_out[i],
		auto_mode => GVL_VALVE.auto_mode[i],
		open_state => GVL_VALVE.open_state[i],
		closed_state => GVL_VALVE.closed_state[i],
		up_out => GVL_VALVE.up_out[i],
		down_out => GVL_VALVE.down_out[i],
		move_out => GVL_VALVE.move_out[i],
		error => GVL_VALVE.error_out[i],
		state => GVL_VALVE.state[i],
		percent_imitation => GVL_VALVE.percent_imitation[i]
	);

END_FOR;


(*
========================================================
	4. КОПИРОВАНИЕ НУЖНЫХ СОСТОЯНИЙ В РЕГУЛЯТОР
========================================================
*)
FOR i := 0 TO counter_armature DO
	GVL_REGULATOR.reg_valve[i].open_state := GVL_VALVE.open_state[i];
	GVL_REGULATOR.reg_valve[i].closed_state := GVL_VALVE.closed_state[i];
END_FOR;


(*
========================================================
	5. ОБЩИЕ СИГНАЛЫ ОТ ИМИТАЦИИ / АРМАТУРЫ
========================================================
*)
GVL_IGNITION.ignition_flame := GVL_VALVE.open_state[ignit];