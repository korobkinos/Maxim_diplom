{attribute 'qualified_only'}
VAR_GLOBAL
	(*
	Плоская карта HMI/OPC UA для состояний и команд горелок.
	Вложенные массивы не используются из-за ограничений Weintek/OPC UA.
	Карта зарезервирована для будущей миграции на несколько горелок.
	На текущую логику одной горелки карта пока не подключена.
	Индексы горелок: 1..burner_quantity.
	*)
	run             : ARRAY[1..burner_quantity] OF BOOL;
	ready           : ARRAY[1..burner_quantity] OF BOOL;
	alarm           : ARRAY[1..burner_quantity] OF BOOL;
	warning         : ARRAY[1..burner_quantity] OF BOOL;
	auto_mode       : ARRAY[1..burner_quantity] OF BOOL;
	manual_mode     : ARRAY[1..burner_quantity] OF BOOL;
	start_cmd       : ARRAY[1..burner_quantity] OF BOOL;
	stop_cmd        : ARRAY[1..burner_quantity] OF BOOL;
	step            : ARRAY[1..burner_quantity] OF WORD;
	state           : ARRAY[1..burner_quantity] OF DWORD;
	load_setpoint   : ARRAY[1..burner_quantity] OF REAL;
	load_feedback   : ARRAY[1..burner_quantity] OF REAL;
END_VAR