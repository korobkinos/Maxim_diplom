FUNCTION_BLOCK protect_on_off_singl
VAR_INPUT
	MAN_ON: BOOL;// Ввести защиту "параметр гор.защиты"
	MAN_OFF: BOOL;// Вывести защиту "параметр гор.защиты"
	TERMINATE_TIME:REAL;//Время прекращения выведенной защиты
END_VAR
VAR_IN_OUT
	Zachita_vvedena: BOOL;//Состояние защиты-1-введена,0-выведена(состояния ввода защиты)
END_VAR
VAR_OUTPUT
END_VAR
VAR
	termination_ton: ton;
	TON_ACTIVE: BOOL;
	//protect_RS: rs;
	//counter:WORD;
END_VAR

// === IMPLEMENTATION ===

IF TERMINATE_TIME <> 0 THEN
	termination_ton(	IN:= Zachita_vvedena=TRUE,
						PT:= REAL_TO_TIME(TERMINATE_TIME*1000),
						Q=> TON_ACTIVE);
END_IF
	//Установка
	//protect_RS(	SET:= MAN_OFF,
		//		RESET1:= MAN_ON  OR TON_ACTIVE);
	
IF MAN_OFF THEN
	Zachita_vvedena:= TRUE;
END_IF
	
IF MAN_ON OR TON_ACTIVE THEN
	Zachita_vvedena:= FALSE;
END_IF