FUNCTION_BLOCK ignition_sequence_singl
VAR_INPUT
	block                   : BOOL;   // Запрет запуска последовательности
	start                   : BOOL;   // Запуск процесса розжига
	stop                    : BOOL;   // Остановка процесса
	reset_error             : BOOL;   // Сброс ошибки процесса

	use_fast_pressure       : BOOL;   // Опрессовка в быстром режиме

	// Обратная связь от блока вентиляции
	vent_success            : BOOL;   // Вентиляция проведена
	vent_in_progress        : BOOL;   // Идёт вентиляция
	vent_state_decoded      : VENT_STATE_STRUCT;

	// Обратная связь от блока опрессовки
	pressure_success        : BOOL;   // Опрессовка проведена
	pressure_in_progress    : BOOL;   // Идёт опрессовка
	pressure_state_decoded  : PRESSURE_STATE_STRUCT;

	// Настройки для расчёта watchdog
	vent_settings           : ventilation_settings;
	pressure_settings       : pressure_settings;
END_VAR

VAR_OUTPUT
	start_ventilation       : BOOL;   // Импульс запуска вентиляции
	start_pressure          : BOOL;   // Импульс запуска обычной опрессовки
	start_pressure_fast     : BOOL;   // Импульс запуска быстрой опрессовки
	start_burner            : BOOL;   // Импульс запуска горелки

	current_step            : WORD;   // Текущий шаг алгоритма

	state_decoded           : IGNITION_SEQ_STATE_STRUCT; // Расшифрованное состояние
	state                   : DWORD;                     // Битовая маска состояния
END_VAR

VAR
	RTC_RESULT              : UDINT;
	clock                   : DWORD;

	step_start_time         : DWORD;
	vent_watchdog_time      : DWORD;
	press_watchdog_time     : DWORD;

	start_active            : BOOL;
	stop_active             : BOOL;
	reset_active            : BOOL;

	start_trig              : R_TRIG;
	stop_trig               : R_TRIG;
	reset_trig              : R_TRIG;

	start_vent_impuls       : impuls_1_sec;
	start_press_impuls      : impuls_1_sec;
	start_press_fast_impuls : impuls_1_sec;
	start_burner_impuls     : impuls_1_sec;

	clear_ton               : ARRAY[1..6] OF TON;
END_VAR

VAR CONSTANT
	// Шаги алгоритма
	ST_IDLE                 : WORD := 0;
	ST_CHECK_VENT           : WORD := 1;
	ST_START_VENT           : WORD := 2;
	ST_WAIT_VENT            : WORD := 3;
	ST_CHECK_PRESSURE       : WORD := 4;
	ST_START_PRESSURE       : WORD := 5;
	ST_WAIT_PRESSURE        : WORD := 6;
	ST_START_BURNER         : WORD := 7;
	ST_DONE                 : WORD := 8;
	ST_ERROR                : WORD := 9;

	// Индексы настроек вентиляции
	V_IDX_PRESTART_TIME     : INT := 1;
	V_IDX_WAIT_IM_TIME      : INT := 6;

	// Индексы настроек опрессовки
	P_IDX_T_WAIT_1          : INT := 3;
	P_IDX_T_WAIT_2          : INT := 4;
	P_IDX_T_WAIT_3          : INT := 5;
	P_IDX_T_FAST            : INT := 6;
END_VAR

// === IMPLEMENTATION ===

// Текущее время ПЛК
clock := SysTimeRTCGet(pResult := RTC_RESULT);

// Сброс импульсных команд по умолчанию
start_vent_impuls(CLK := FALSE, Q => start_ventilation);
start_press_impuls(CLK := FALSE, Q => start_pressure);
start_press_fast_impuls(CLK := FALSE, Q => start_pressure_fast);
start_burner_impuls(CLK := FALSE, Q => start_burner);

// Расчёт watchdog вентиляции
// Время вентиляции + ожидание вентилятора + предварительное закрытие шибера
// + открытие шибера + финальное закрытие шибера + запас 10 сек
vent_watchdog_time :=
	REAL_TO_DWORD(vent_settings.Value[V_IDX_PRESTART_TIME]) +
	4 * REAL_TO_DWORD(vent_settings.Value[V_IDX_WAIT_IM_TIME]) +
	10;

// Расчёт watchdog опрессовки
IF use_fast_pressure THEN
	press_watchdog_time :=
		REAL_TO_DWORD(pressure_settings.Value[P_IDX_T_WAIT_1]) +
		REAL_TO_DWORD(pressure_settings.Value[P_IDX_T_FAST]) +
		10;
ELSE
	press_watchdog_time :=
		REAL_TO_DWORD(pressure_settings.Value[P_IDX_T_WAIT_1]) +
		REAL_TO_DWORD(pressure_settings.Value[P_IDX_T_WAIT_2]) +
		REAL_TO_DWORD(pressure_settings.Value[P_IDX_T_WAIT_3]) +
		10;
END_IF;


// Сброс ошибки процесса
reset_trig(CLK := reset_error, Q => reset_active);
IF reset_active THEN
	state_decoded.success := FALSE;
	state_decoded.in_progress := FALSE;
	state_decoded.error := FALSE;
	state_decoded.wait_ventilation := FALSE;
	state_decoded.wait_pressure := FALSE;
	state_decoded.start_burner_done := FALSE;
	state_decoded.vent_skipped_done := FALSE;
	state_decoded.pressure_skipped_done := FALSE;
	state_decoded.vent_watchdog_error := FALSE;
	state_decoded.press_watchdog_error := FALSE;
	state_decoded.stopped := FALSE;

	state_decoded.msg_vent_error := FALSE;
	state_decoded.msg_press_error := FALSE;
	state_decoded.msg_vent_watchdog := FALSE;
	state_decoded.msg_press_watchdog := FALSE;
	state_decoded.msg_stopped := FALSE;
	state_decoded.process_success_imp := FALSE;

	current_step := ST_IDLE;
END_IF;


// Остановка процесса
stop_trig(CLK := stop, Q => stop_active);
IF stop_active AND state_decoded.in_progress THEN
	state_decoded.in_progress := FALSE;
	state_decoded.stopped := TRUE;
	state_decoded.wait_ventilation := FALSE;
	state_decoded.wait_pressure := FALSE;
	state_decoded.msg_stopped := TRUE;

	current_step := ST_IDLE;
END_IF;


// Старт процесса
start_trig(CLK := start, Q => start_active);
IF start_trig.Q AND NOT block AND NOT state_decoded.in_progress THEN
	state_decoded.success := FALSE;
	state_decoded.in_progress := TRUE;
	state_decoded.error := FALSE;
	state_decoded.wait_ventilation := FALSE;
	state_decoded.wait_pressure := FALSE;
	state_decoded.start_burner_done := FALSE;
	state_decoded.vent_skipped_done := FALSE;
	state_decoded.pressure_skipped_done := FALSE;
	state_decoded.vent_watchdog_error := FALSE;
	state_decoded.press_watchdog_error := FALSE;
	state_decoded.stopped := FALSE;

	state_decoded.msg_vent_error := FALSE;
	state_decoded.msg_press_error := FALSE;
	state_decoded.msg_vent_watchdog := FALSE;
	state_decoded.msg_press_watchdog := FALSE;
	state_decoded.msg_stopped := FALSE;
	state_decoded.process_success_imp := FALSE;

	current_step := ST_CHECK_VENT;
END_IF;


// Автомат последовательности
CASE current_step OF

	ST_IDLE:
		// ожидание запуска


	ST_CHECK_VENT:
		IF vent_success THEN
			state_decoded.vent_skipped_done := TRUE;
			current_step := ST_CHECK_PRESSURE;
		ELSE
			current_step := ST_START_VENT;
		END_IF


	ST_START_VENT:
		start_vent_impuls(CLK := TRUE, Q => start_ventilation);
		step_start_time := clock;
		state_decoded.wait_ventilation := TRUE;
		current_step := ST_WAIT_VENT;


	ST_WAIT_VENT:
		IF vent_success THEN
			state_decoded.wait_ventilation := FALSE;
			current_step := ST_CHECK_PRESSURE;

		ELSIF vent_state_decoded.msg_fail
		   OR vent_state_decoded.fan_start_error
		   OR vent_state_decoded.shiber_init_error
		   OR vent_state_decoded.shiber_open_error
		   OR vent_state_decoded.fan_lost
		   OR vent_state_decoded.shiber_close_error THEN

			state_decoded.wait_ventilation := FALSE;
			state_decoded.error := TRUE;
			state_decoded.msg_vent_error := TRUE;
			current_step := ST_ERROR;

		ELSIF clock - step_start_time >= vent_watchdog_time THEN
			state_decoded.wait_ventilation := FALSE;
			state_decoded.error := TRUE;
			state_decoded.vent_watchdog_error := TRUE;
			state_decoded.msg_vent_watchdog := TRUE;
			current_step := ST_ERROR;
		END_IF


	ST_CHECK_PRESSURE:
		IF pressure_success THEN
			state_decoded.pressure_skipped_done := TRUE;
			current_step := ST_START_BURNER;
		ELSE
			current_step := ST_START_PRESSURE;
		END_IF


	ST_START_PRESSURE:
		IF use_fast_pressure THEN
			start_press_fast_impuls(CLK := TRUE, Q => start_pressure_fast);
		ELSE
			start_press_impuls(CLK := TRUE, Q => start_pressure);
		END_IF

		step_start_time := clock;
		state_decoded.wait_pressure := TRUE;
		current_step := ST_WAIT_PRESSURE;


	ST_WAIT_PRESSURE:
		IF pressure_success THEN
			state_decoded.wait_pressure := FALSE;
			current_step := ST_START_BURNER;

		ELSIF pressure_state_decoded.msg_fail
		   OR pressure_state_decoded.kb_not_closed
		   OR pressure_state_decoded.pzk1_leak
		   OR pressure_state_decoded.overpressure
		   OR pressure_state_decoded.leak THEN

			state_decoded.wait_pressure := FALSE;
			state_decoded.error := TRUE;
			state_decoded.msg_press_error := TRUE;
			current_step := ST_ERROR;

		ELSIF clock - step_start_time >= press_watchdog_time THEN
			state_decoded.wait_pressure := FALSE;
			state_decoded.error := TRUE;
			state_decoded.press_watchdog_error := TRUE;
			state_decoded.msg_press_watchdog := TRUE;
			current_step := ST_ERROR;
		END_IF


	ST_START_BURNER:
		start_burner_impuls(CLK := TRUE, Q => start_burner);
		state_decoded.start_burner_done := TRUE;
		current_step := ST_DONE;


	ST_DONE:
		state_decoded.in_progress := FALSE;
		state_decoded.success := TRUE;
		state_decoded.wait_ventilation := FALSE;
		state_decoded.wait_pressure := FALSE;
		state_decoded.process_success_imp := TRUE;
		current_step := ST_IDLE;


	ST_ERROR:
		state_decoded.in_progress := FALSE;
		state_decoded.success := FALSE;
		state_decoded.wait_ventilation := FALSE;
		state_decoded.wait_pressure := FALSE;

END_CASE;


// Таймеры автосброса одноразовых сообщений и импульсов
clear_ton[1](IN := state_decoded.msg_vent_error,      PT := T#1S);
clear_ton[2](IN := state_decoded.msg_press_error,     PT := T#1S);
clear_ton[3](IN := state_decoded.msg_vent_watchdog,   PT := T#1S);
clear_ton[4](IN := state_decoded.msg_press_watchdog,  PT := T#1S);
clear_ton[5](IN := state_decoded.msg_stopped,         PT := T#1S);
clear_ton[6](IN := state_decoded.process_success_imp, PT := T#1S);

// Автосброс одноразовых сообщений и импульсов
IF clear_ton[1].Q THEN state_decoded.msg_vent_error := FALSE; END_IF
IF clear_ton[2].Q THEN state_decoded.msg_press_error := FALSE; END_IF
IF clear_ton[3].Q THEN state_decoded.msg_vent_watchdog := FALSE; END_IF
IF clear_ton[4].Q THEN state_decoded.msg_press_watchdog := FALSE; END_IF
IF clear_ton[5].Q THEN state_decoded.msg_stopped := FALSE; END_IF
IF clear_ton[6].Q THEN state_decoded.process_success_imp := FALSE; END_IF


// Формирование DWORD из структуры
state := 0;
state.0 := state_decoded.success;
state.1 := state_decoded.in_progress;
state.2 := state_decoded.error;
state.3 := state_decoded.wait_ventilation;
state.4 := state_decoded.wait_pressure;
state.5 := state_decoded.start_burner_done;
state.6 := state_decoded.vent_skipped_done;
state.7 := state_decoded.pressure_skipped_done;
state.8 := state_decoded.vent_watchdog_error;
state.9 := state_decoded.press_watchdog_error;
state.10 := state_decoded.stopped;
state.11 := state_decoded.msg_vent_error;
state.12 := state_decoded.msg_press_error;
state.13 := state_decoded.msg_vent_watchdog;
state.14 := state_decoded.msg_press_watchdog;
state.15 := state_decoded.msg_stopped;
state.16 := state_decoded.process_success_imp;
state.17 := state_decoded.reserved_17;