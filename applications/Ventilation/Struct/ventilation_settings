TYPE ventilation_settings :
STRUCT
	VALUE : ARRAY[1..7] OF REAL := [600, 10, 70, 1, 1, 60, 0];
	// 1 - Уставка времени предпусковой вентиляции, сек
	// 2 - Уставка времени актуальности вентиляции, часы
	// 3 - Уставка времени послеаварийной вентиляции, сек
	// 4 - Вентилятор горелки: 1 = есть, 0 = нет
	// 5 - Вентиляция вообще: 1 = есть, 0 = нет
	// 6 - Время ожидания ИМ вентиляции для ошибки, сек
	// 7 - Послеаварийная вентиляция без пуска/контроля вентилятора: 1 = да, 0 = нет
END_STRUCT
END_TYPE