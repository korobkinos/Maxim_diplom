FUNCTION_BLOCK ventilation_singl
VAR_INPUT
	block                  : BOOL;   // Запрет запуска вентиляции
	start                  : BOOL;   // Запуск предпусковой вентиляции
	start_post_emergency   : BOOL;   // Запуск послеаварийной вентиляции
	stop                   : BOOL;   // Отмена вентиляции в процессе
	reset_ventilation      : BOOL;   // Сброс признака "вентиляция проведена"
	skip                   : BOOL;   // Пропуск вентиляции оператором

	fan_on_state           : BOOL;   // Вентилятор включен
	shiber_open_state      : BOOL;   // Шибер открыт
	shiber_closed_state    : BOOL;   // Шибер закрыт

	vent_settings          : ventilation_settings;
	// Value[1] = Уставка времени предпусковой вентиляции, сек
	// Value[2] = Уставка времени актуальности вентиляции, часы
	// Value[3] = Уставка времени послеаварийной вентиляции, сек
	// Value[4] = Вентилятор горелки: 1 = есть, 0 = нет
	// Value[5] = Вентиляция вообще: 1 = есть, 0 = нет
	// Value[6] = Время ожидания ИМ вентиляции для ошибки, сек
	// Value[7] = Послеаварийная вентиляция без пуска/контроля вентилятора: 1 = да, 0 = нет
END_VAR

VAR_OUTPUT
	fan_on                 : BOOL;   // Импульс на включение вентилятора
	shiber_open            : BOOL;   // Импульс на открытие шибера
	shiber_close           : BOOL;   // Импульс на закрытие шибера

	time_actual            : WORD;   // Остаток времени вентиляции, сек
	time_left_sec          : DWORD;  // Остаток времени вентиляции, сек

	vent_state_decoded     : VENT_STATE_STRUCT; // Расшифрованное состояние
	vent_state             : DWORD;             // Битовая маска состояния
END_VAR

VAR
	RTC_RESULT             : UDINT;
	clock                  : DWORD;
	clock_memory           : DWORD;
	click                  : BOOL;

	time_success           : DWORD; // Время успешной вентиляции / пропуска
	time_stage_start       : DWORD; // Время старта текущей стадии
	vent_elapsed_sec       : DWORD; // Накопленное время вентиляции
	vent_required_sec      : DWORD; // Требуемое время вентиляции

	case_counter           : WORD;
	start_active           : BOOL;
	start_post_active      : BOOL;
	reset_active           : BOOL;

	start_trig             : R_TRIG;
	start_post_trig        : R_TRIG;
	reset_trig             : R_TRIG;

	fan_on_impuls          : impuls_1_sec;
	shiber_open_impuls     : impuls_1_sec;
	shiber_close_impuls    : impuls_1_sec;

	clear_ton              : ARRAY[1..15] OF TON;

	has_burner_fan         : BOOL;
	has_ventilation        : BOOL;
	post_emerg_no_fan      : BOOL;
	use_fan_in_current_mode: BOOL;
END_VAR

VAR CONSTANT
	// Индексы настроек
	IDX_PRESTART_TIME      : INT := 1;
	IDX_VALID_TIME_H       : INT := 2;
	IDX_POST_EMERG_TIME    : INT := 3;
	IDX_BURNER_FAN_EXISTS  : INT := 4;
	IDX_VENT_EXISTS        : INT := 5;
	IDX_WAIT_IM_TIME       : INT := 6;
	IDX_POST_EMERG_NO_FAN  : INT := 7;

	// Стадии автомата
	ST_IDLE                : WORD := 0;
	ST_CHECK_SHIBER_INIT   : WORD := 1;
	ST_PRE_CLOSE_SHIBER    : WORD := 2;
	ST_WAIT_PRE_CLOSE      : WORD := 3;
	ST_START_FAN           : WORD := 4;
	ST_WAIT_FAN_ON         : WORD := 5;
	ST_OPEN_SHIBER         : WORD := 6;
	ST_WAIT_SHIBER_OPEN    : WORD := 7;
	ST_VENTILATION         : WORD := 8;
	ST_CLOSE_SHIBER        : WORD := 9;
	ST_WAIT_SHIBER_CLOSE   : WORD := 10;
	ST_SUCCESS             : WORD := 11;
	ST_EXIT                : WORD := 12;
	ST_FINISH              : WORD := 13;
END_VAR

// === IMPLEMENTATION ===

// Текущее время ПЛК
clock := SysTimeRTCGet(pResult := RTC_RESULT);

// Формирование тика 1 сек
click := FALSE;
IF clock - clock_memory >= 1 THEN
	click := TRUE;
	clock_memory := clock;
END_IF;

// Сброс импульсных команд по умолчанию
fan_on_impuls(CLK := FALSE, Q => fan_on);
shiber_open_impuls(CLK := FALSE, Q => shiber_open);
shiber_close_impuls(CLK := FALSE, Q => shiber_close);

// Конфигурация объекта
has_burner_fan := REAL_TO_DWORD(vent_settings.Value[IDX_BURNER_FAN_EXISTS]) = 1;
has_ventilation := REAL_TO_DWORD(vent_settings.Value[IDX_VENT_EXISTS]) = 1;
post_emerg_no_fan := REAL_TO_DWORD(vent_settings.Value[IDX_POST_EMERG_NO_FAN]) = 1;

// Остаток времени вентиляции
IF vent_required_sec >= vent_elapsed_sec THEN
	time_left_sec := vent_required_sec - vent_elapsed_sec;
ELSE
	time_left_sec := 0;
END_IF;

time_actual := DWORD_TO_WORD(time_left_sec);


// Пропуск вентиляции оператором
IF skip AND NOT block AND NOT vent_state_decoded.in_progress THEN
	time_success := clock;

	vent_state_decoded.success := TRUE;
	vent_state_decoded.skipped := TRUE;
	vent_state_decoded.skip_success := TRUE;
	vent_state_decoded.msg_success := TRUE;

	case_counter := ST_FINISH;
END_IF;


// Сброс признака "вентиляция проведена"
reset_trig(CLK := reset_ventilation, Q => reset_active);
IF reset_active THEN
	IF vent_state_decoded.success THEN
		vent_state_decoded.success := FALSE;
		vent_state_decoded.reset_done := TRUE;
	END_IF
END_IF;


// Автоматический сброс признака "вентиляция проведена"
IF vent_state_decoded.success THEN
	IF clock - time_success >= 3600 * REAL_TO_DWORD(vent_settings.Value[IDX_VALID_TIME_H]) THEN
		vent_state_decoded.success := FALSE;
		vent_state_decoded.timeout_reset := TRUE;
	END_IF
END_IF;


// Отмена текущей вентиляции
IF stop AND vent_state_decoded.in_progress THEN
	vent_state_decoded.cancelled := TRUE;
	vent_state_decoded.msg_fail := TRUE;
	case_counter := ST_EXIT;
END_IF;


// Старт предпусковой вентиляции
start_trig(CLK := start, Q => start_active);
IF start_trig.Q AND NOT block AND NOT vent_state_decoded.success AND NOT vent_state_decoded.in_progress THEN
	vent_required_sec := REAL_TO_DWORD(vent_settings.Value[IDX_PRESTART_TIME]);
	vent_elapsed_sec := 0;
	time_left_sec := vent_required_sec;

	use_fan_in_current_mode := has_burner_fan;

	vent_state_decoded.skipped := FALSE;
	vent_state_decoded.cancelled := FALSE;
	vent_state_decoded.fan_start_error := FALSE;
	vent_state_decoded.shiber_open_error := FALSE;
	vent_state_decoded.fan_lost := FALSE;
	vent_state_decoded.shiber_reopen := FALSE;
	vent_state_decoded.timeout_reset := FALSE;
	vent_state_decoded.reset_done := FALSE;
	vent_state_decoded.msg_success := FALSE;
	vent_state_decoded.msg_fail := FALSE;
	vent_state_decoded.prestart_success := FALSE;
	vent_state_decoded.skip_success := FALSE;
	vent_state_decoded.shiber_close_error := FALSE;
	vent_state_decoded.post_emergency_success := FALSE;
	vent_state_decoded.post_emergency_active := FALSE;
	vent_state_decoded.prestart_active := TRUE;
	vent_state_decoded.shiber_init_error := FALSE;

	vent_state_decoded.in_progress := TRUE;

	IF NOT has_ventilation THEN
		vent_state_decoded.success := TRUE;
		vent_state_decoded.msg_success := TRUE;
		vent_state_decoded.prestart_success := TRUE;
		time_success := clock;
		case_counter := ST_FINISH;
	ELSE
		case_counter := ST_CHECK_SHIBER_INIT;
	END_IF
END_IF;


// Старт послеаварийной вентиляции
start_post_trig(CLK := start_post_emergency, Q => start_post_active);
IF start_post_trig.Q AND NOT block AND NOT vent_state_decoded.success AND NOT vent_state_decoded.in_progress THEN
	vent_required_sec := REAL_TO_DWORD(vent_settings.Value[IDX_POST_EMERG_TIME]);
	vent_elapsed_sec := 0;
	time_left_sec := vent_required_sec;

	IF post_emerg_no_fan THEN
		use_fan_in_current_mode := FALSE;
	ELSE
		use_fan_in_current_mode := has_burner_fan;
	END_IF

	vent_state_decoded.skipped := FALSE;
	vent_state_decoded.cancelled := FALSE;
	vent_state_decoded.fan_start_error := FALSE;
	vent_state_decoded.shiber_open_error := FALSE;
	vent_state_decoded.fan_lost := FALSE;
	vent_state_decoded.shiber_reopen := FALSE;
	vent_state_decoded.timeout_reset := FALSE;
	vent_state_decoded.reset_done := FALSE;
	vent_state_decoded.msg_success := FALSE;
	vent_state_decoded.msg_fail := FALSE;
	vent_state_decoded.prestart_success := FALSE;
	vent_state_decoded.skip_success := FALSE;
	vent_state_decoded.shiber_close_error := FALSE;
	vent_state_decoded.post_emergency_success := FALSE;
	vent_state_decoded.post_emergency_active := TRUE;
	vent_state_decoded.prestart_active := FALSE;
	vent_state_decoded.shiber_init_error := FALSE;

	vent_state_decoded.in_progress := TRUE;

	IF NOT has_ventilation THEN
		vent_state_decoded.success := TRUE;
		vent_state_decoded.msg_success := TRUE;
		vent_state_decoded.post_emergency_success := TRUE;
		time_success := clock;
		case_counter := ST_FINISH;
	ELSE
		case_counter := ST_CHECK_SHIBER_INIT;
	END_IF
END_IF;


// Автомат стадий
CASE case_counter OF

	ST_CHECK_SHIBER_INIT:
		// Для объектов с вентилятором ШВ перед пуском вентилятора
		// должен быть гарантированно закрыт.
		// Поэтому:
		// - если закрыт -> можно запускать вентилятор
		// - если открыт или в промежуточном положении -> сначала закрываем
		// - если оба концевика активны -> ошибка

		IF shiber_closed_state AND NOT shiber_open_state THEN
			IF use_fan_in_current_mode THEN
				case_counter := ST_START_FAN;
			ELSE
				case_counter := ST_OPEN_SHIBER;
			END_IF

		ELSIF shiber_open_state AND shiber_closed_state THEN
			vent_state_decoded.shiber_init_error := TRUE;
			vent_state_decoded.msg_fail := TRUE;
			case_counter := ST_EXIT;

		ELSIF fan_on_state AND NOT shiber_open_state  THEN
			case_counter := ST_OPEN_SHIBER;
			
		ELSE
			// ШВ открыт или стоит между концевиками
			case_counter := ST_PRE_CLOSE_SHIBER;
		END_IF


	ST_PRE_CLOSE_SHIBER:
		shiber_close_impuls(CLK := TRUE, Q => shiber_close);
		time_stage_start := clock;
		case_counter := ST_WAIT_PRE_CLOSE;


	ST_WAIT_PRE_CLOSE:
		IF shiber_closed_state AND NOT shiber_open_state THEN
			IF use_fan_in_current_mode THEN
				case_counter := ST_START_FAN;
			ELSE
				case_counter := ST_OPEN_SHIBER;
			END_IF

		ELSIF clock - time_stage_start >= REAL_TO_DWORD(vent_settings.Value[IDX_WAIT_IM_TIME]) THEN
			vent_state_decoded.shiber_init_error := TRUE;
			vent_state_decoded.msg_fail := TRUE;
			case_counter := ST_EXIT;
		END_IF


	ST_START_FAN:
		fan_on_impuls(CLK := TRUE, Q => fan_on);
		time_stage_start := clock;
		case_counter := ST_WAIT_FAN_ON;


	ST_WAIT_FAN_ON:
		IF fan_on_state THEN
			case_counter := ST_OPEN_SHIBER;

		ELSIF clock - time_stage_start >= REAL_TO_DWORD(vent_settings.Value[IDX_WAIT_IM_TIME]) THEN
			vent_state_decoded.fan_start_error := TRUE;
			vent_state_decoded.msg_fail := TRUE;
			case_counter := ST_EXIT;
		END_IF


	ST_OPEN_SHIBER:
		shiber_open_impuls(CLK := TRUE, Q => shiber_open);
		time_stage_start := clock;
		case_counter := ST_WAIT_SHIBER_OPEN;


	ST_WAIT_SHIBER_OPEN:
		IF shiber_open_state AND NOT shiber_closed_state THEN
			case_counter := ST_VENTILATION;

		ELSIF clock - time_stage_start >= REAL_TO_DWORD(vent_settings.Value[IDX_WAIT_IM_TIME]) THEN
			vent_state_decoded.shiber_open_error := TRUE;
			vent_state_decoded.msg_fail := TRUE;
			case_counter := ST_EXIT;
		END_IF


	ST_VENTILATION:
		IF use_fan_in_current_mode AND NOT fan_on_state THEN
			vent_elapsed_sec := 0;
			time_left_sec := vent_required_sec;
			vent_state_decoded.fan_lost := TRUE;
			vent_state_decoded.msg_fail := TRUE;
			case_counter := ST_EXIT;

		ELSIF NOT shiber_open_state OR shiber_closed_state THEN
			shiber_open_impuls(CLK := TRUE, Q => shiber_open);
			vent_state_decoded.shiber_reopen := TRUE;

		ELSE
			IF click THEN
				IF vent_elapsed_sec < vent_required_sec THEN
					vent_elapsed_sec := vent_elapsed_sec + 1;
				END_IF
			END_IF

			IF vent_elapsed_sec >= vent_required_sec THEN
				case_counter := ST_CLOSE_SHIBER;
			END_IF
		END_IF


	ST_CLOSE_SHIBER:
		shiber_close_impuls(CLK := TRUE, Q => shiber_close);
		time_stage_start := clock;
		case_counter := ST_WAIT_SHIBER_CLOSE;


	ST_WAIT_SHIBER_CLOSE:
		IF shiber_closed_state AND NOT shiber_open_state THEN
			case_counter := ST_SUCCESS;

		ELSIF clock - time_stage_start >= REAL_TO_DWORD(vent_settings.Value[IDX_WAIT_IM_TIME]) THEN
			vent_state_decoded.shiber_close_error := TRUE;
			vent_state_decoded.msg_fail := TRUE;
			case_counter := ST_FINISH;
		END_IF


	ST_SUCCESS:
		vent_state_decoded.success := TRUE;
		vent_state_decoded.msg_success := TRUE;

		IF vent_state_decoded.post_emergency_active THEN
			vent_state_decoded.post_emergency_success := TRUE;
		ELSE
			vent_state_decoded.prestart_success := TRUE;
		END_IF

		time_success := clock;
		case_counter := ST_FINISH;


	ST_EXIT:
		shiber_close_impuls(CLK := TRUE, Q => shiber_close);
		case_counter := ST_FINISH;


	ST_FINISH:
		vent_state_decoded.in_progress := FALSE;
		vent_state_decoded.prestart_active := FALSE;
		vent_state_decoded.post_emergency_active := FALSE;
		use_fan_in_current_mode := FALSE;
		case_counter := ST_IDLE;


	ST_IDLE:
		// ожидание

END_CASE;


// Таймеры автосброса одноразовых сообщений
clear_ton[1](IN := vent_state_decoded.skipped,                 PT := T#1S);
clear_ton[2](IN := vent_state_decoded.cancelled,               PT := T#1S);
clear_ton[3](IN := vent_state_decoded.fan_start_error,         PT := T#1S);
clear_ton[4](IN := vent_state_decoded.shiber_open_error,       PT := T#1S);
clear_ton[5](IN := vent_state_decoded.fan_lost,                PT := T#1S);
clear_ton[6](IN := vent_state_decoded.shiber_reopen,           PT := T#1S);
clear_ton[7](IN := vent_state_decoded.timeout_reset,           PT := T#1S);
clear_ton[8](IN := vent_state_decoded.reset_done,              PT := T#1S);
clear_ton[9](IN := vent_state_decoded.msg_success,             PT := T#1S);
clear_ton[10](IN := vent_state_decoded.msg_fail,               PT := T#1S);
clear_ton[11](IN := vent_state_decoded.prestart_success,       PT := T#1S);
clear_ton[12](IN := vent_state_decoded.skip_success,           PT := T#1S);
clear_ton[13](IN := vent_state_decoded.shiber_close_error,     PT := T#1S);
clear_ton[14](IN := vent_state_decoded.post_emergency_success, PT := T#1S);
clear_ton[15](IN := vent_state_decoded.shiber_init_error,      PT := T#1S);

// Автосброс одноразовых сообщений
IF clear_ton[1].Q THEN vent_state_decoded.skipped := FALSE; END_IF
IF clear_ton[2].Q THEN vent_state_decoded.cancelled := FALSE; END_IF
IF clear_ton[3].Q THEN vent_state_decoded.fan_start_error := FALSE; END_IF
IF clear_ton[4].Q THEN vent_state_decoded.shiber_open_error := FALSE; END_IF
IF clear_ton[5].Q THEN vent_state_decoded.fan_lost := FALSE; END_IF
IF clear_ton[6].Q THEN vent_state_decoded.shiber_reopen := FALSE; END_IF
IF clear_ton[7].Q THEN vent_state_decoded.timeout_reset := FALSE; END_IF
IF clear_ton[8].Q THEN vent_state_decoded.reset_done := FALSE; END_IF
IF clear_ton[9].Q THEN vent_state_decoded.msg_success := FALSE; END_IF
IF clear_ton[10].Q THEN vent_state_decoded.msg_fail := FALSE; END_IF
IF clear_ton[11].Q THEN vent_state_decoded.prestart_success := FALSE; END_IF
IF clear_ton[12].Q THEN vent_state_decoded.skip_success := FALSE; END_IF
IF clear_ton[13].Q THEN vent_state_decoded.shiber_close_error := FALSE; END_IF
IF clear_ton[14].Q THEN vent_state_decoded.post_emergency_success := FALSE; END_IF
IF clear_ton[15].Q THEN vent_state_decoded.shiber_init_error := FALSE; END_IF


// Формирование DWORD из структуры
vent_state := 0;
vent_state.0 := vent_state_decoded.success;
vent_state.1 := vent_state_decoded.in_progress;
vent_state.2 := vent_state_decoded.skipped;
vent_state.3 := vent_state_decoded.cancelled;
vent_state.4 := vent_state_decoded.fan_start_error;
vent_state.5 := vent_state_decoded.shiber_open_error;
vent_state.6 := vent_state_decoded.fan_lost;
vent_state.7 := vent_state_decoded.shiber_reopen;
vent_state.8 := vent_state_decoded.timeout_reset;
vent_state.9 := vent_state_decoded.reset_done;
vent_state.10 := vent_state_decoded.msg_success;
vent_state.11 := vent_state_decoded.msg_fail;
vent_state.12 := vent_state_decoded.prestart_success;
vent_state.13 := vent_state_decoded.skip_success;
vent_state.14 := vent_state_decoded.shiber_close_error;
vent_state.15 := vent_state_decoded.post_emergency_success;
vent_state.16 := vent_state_decoded.post_emergency_active;
vent_state.17 := vent_state_decoded.prestart_active;
vent_state.18 := vent_state_decoded.shiber_init_error;