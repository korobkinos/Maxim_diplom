TYPE IGNITION_SEQ_STATE_STRUCT :
STRUCT
	success                : BOOL; // bit0  - Процесс розжига завершён успешно
	in_progress            : BOOL; // bit1  - Процесс розжига идёт
	error                  : BOOL; // bit2  - Ошибка процесса

	wait_ventilation       : BOOL; // bit3  - Ожидание вентиляции
	wait_pressure          : BOOL; // bit4  - Ожидание опрессовки
	start_burner_done      : BOOL; // bit5  - Выдан импульс запуска горелки

	vent_skipped_done      : BOOL; // bit6  - Вентиляция уже была выполнена и шаг пропущен
	pressure_skipped_done  : BOOL; // bit7  - Опрессовка уже была выполнена и шаг пропущен

	vent_watchdog_error    : BOOL; // bit8  - Превышено время ожидания вентиляции
	press_watchdog_error   : BOOL; // bit9  - Превышено время ожидания опрессовки

	stopped                : BOOL; // bit10 - Процесс остановлен оператором

	msg_vent_error         : BOOL; // bit11 - Сообщение: ошибка вентиляции
	msg_press_error        : BOOL; // bit12 - Сообщение: ошибка опрессовки
	msg_vent_watchdog      : BOOL; // bit13 - Сообщение: таймаут ожидания вентиляции
	msg_press_watchdog     : BOOL; // bit14 - Сообщение: таймаут ожидания опрессовки
	msg_stopped            : BOOL; // bit15 - Сообщение: процесс остановлен оператором

	process_success_imp    : BOOL; // bit16 - Импульс: последовательность завершена успешно
	reserved_17            : BOOL; // bit17 - резерв
END_STRUCT
END_TYPE