PROGRAM BLOCKS
VAR
END_VAR

// === IMPLEMENTATION ===

(*
========================================================
	БЛОКИРОВКИ АРМАТУРЫ И АЛГОРИТМОВ
========================================================
*)


(*
--------------------------------------------------------
	Блокировка ПЗК-1
--------------------------------------------------------
	ПЗК-1 блокируется если:
	1. Есть общая авария / неисправность
	2. ПЗК-2 открыт или не подтверждено его закрытие
	3. Не выполнена вентиляция
*)
GVL_BLOCKS.valves_blocks[pzk_1] :=
	GVL_PROTECT.main_alarm
	OR GVL_VALVE.open_state[pzk_2]
	OR NOT GVL_VALVE.closed_state[pzk_2]
	OR NOT GVL_VENTILATION.vent_state_decoded.success;


(*
--------------------------------------------------------
	Блокировка ПЗК-2
--------------------------------------------------------
	ПЗК-2 блокируется, если:
	1. Нет пламени запальника
	2. Нет пламени горелки
*)
GVL_BLOCKS.valves_blocks[pzk_2] :=
	NOT GVL_VALVE.open_state[ignit]
	AND NOT GVL_VALVE.open_state[pilot];


(*
--------------------------------------------------------
	Блокировка вентилятора горелки
--------------------------------------------------------
	Вентилятор нельзя запускать, пока не закрыт
	шибер воздуха
*)
GVL_BLOCKS.valves_blocks[vent_burner] :=
	NOT GVL_VALVE.closed_state[air_shiber];


(*
--------------------------------------------------------
	Блокировка запуска горелки
--------------------------------------------------------
	Розжиг горелки блокируется, если:
	1. Уже идёт процесс розжига
	2. Не выполнена опрессовка
	3. Не выполнена вентиляция
*)
GVL_BURNER.burner_block :=
	GVL_BURNER.boiler_in_process
	OR NOT GVL_PRESSURE.Pressure_state_structure.success
	OR NOT GVL_VENTILATION.vent_state_decoded.success;


(*
--------------------------------------------------------
	Блокировка запуска запальника
--------------------------------------------------------
	Запальник блокируется, если:
	1. Котёл находится в розжиге
	2. Котёл уже в работе
	3. Не выполнена опрессовка
	4. Не выполнена вентиляция
*)
GVL_IGNITION.start_block :=
	GVL_BURNER.boiler_run
	OR NOT GVL_PRESSURE.Pressure_state_structure.success
	OR NOT GVL_VENTILATION.vent_state_decoded.success;


(*
--------------------------------------------------------
	Блокировка искры
--------------------------------------------------------
	Искра запрещена, пока не выполнена вентиляция
*)
GVL_VALVE.block[spark] :=
	NOT GVL_VENTILATION.vent_state_decoded.success;