FUNCTION_BLOCK pressure_singl
VAR_INPUT
	block                : BOOL;   // Запрет запуска автоматической опрессовки
	start                : BOOL;   // Запуск автоматической опрессовки
	stop                 : BOOL;   // Остановка опрессовки в процессе
	abort                : BOOL;   // Сброс успешной опрессовки
	abort_block          : BOOL;   // Запрет сброса успешной опрессовки
	skip                 : BOOL;   // Пропуск опрессовки оператором
	fast_auto            : BOOL;   // Запуск быстрой опрессовки

	Pressure_sensor_in   : REAL;   // Аналоговый датчик давления
	KB_on_state          : BOOL;   // Клапан безопасности закрыт
	PZK_1_on_state       : BOOL;   // ПЗК-1 открыт

	P_max_active         : BOOL;   // Дискретный датчик "достигнуто максимальное давление"
	P_min_active         : BOOL;   // Дискретный датчик "достигнуто минимальное давление"

	pressure_source_mode : USINT;  // 0-аналог, 1-дискретные, 2-комбинированно

	Pressure_settings    : pressure_settings;
	// Value[1] = P_min, минимальное давление опрессовки
	// Value[2] = P_max, максимальное давление опрессовки
	// Value[3] = t_wait_1, выдержка перед подачей давления, сек
	// Value[4] = t_wait_2, время достижения P_min без достижения P_max, сек
	// Value[5] = t_wait_3, время достижения P_max / удержания давления, сек
	// Value[6] = t_fast, время быстрой опрессовки, сек
	// Value[7] = t_termination, время актуальности опрессовки, часы
	// Value[8] = наличие датчика КБ: 1 = есть, 0 = нет
	// Value[9] = режим опрессовки: 0 = через КО, 1 = через ПЗК-1
END_VAR

VAR_OUTPUT
	KB_on                  : BOOL;   // Команда на закрытие КБ
	KB_off                 : BOOL;   // Команда на открытие КБ
	KO_on                  : BOOL;   // Команда на открытие КО
	KO_off                 : BOOL;   // Команда на закрытие КО
	PZK_1_on               : BOOL;   // Команда на открытие ПЗК-1
	PZK_1_off              : BOOL;   // Команда на закрытие ПЗК-1

	P_max_out              : BOOL;   // Признак достигнут максимум
	P_min_out              : BOOL;   // Признак достигнут минимум

	Pressure_state_decoded : PRESSURE_STATE_STRUCT; // Состояние в расшифрованном виде
	Pressure_state         : DWORD;                 // Битовая маска состояния
	// bit0  - Опрессовано
	// bit1  - Идёт опрессовка
	// bit2  - Опрессовка пропущена оператором
	// bit4  - КБ не закрыт
	// bit5  - ПЗК-1 не плотен
	// bit7  - Запрещено пропускать опрессовку
	// bit8  - Опрессовка отменена по таймеру
	// bit9  - Опрессовка отменена оператором
	// bit10 - Сообщение "Опрессовано"
	// bit11 - Сообщение "Не опрессовано"
	// bit12 - Давление велико, проверьте шайбу
	// bit13 - Утечка ПЗК-2, КБ или КЗ
	// bit14 - Полная опрессовка выполнена
	// bit15 - Быстрая опрессовка выполнена
	// bit17 - Запрещено отменять опрессовку
END_VAR

VAR
	RTC_RESULT          : UDINT;
	clock               : DWORD;

	time_success        : DWORD;
	time_case_0         : DWORD;
	add_time            : DWORD;

	case_counter        : WORD;
	start_active        : BOOL;
	abort_active        : BOOL;

	Pressure_start_trig : R_TRIG;
	abort_trig          : R_TRIG;
	fast_rs             : RS;

	clear_ton           : ARRAY[1..13] OF TON;

	KB_on_impuls        : impuls_1_sec;
	KB_off_impuls       : impuls_1_sec;
	KO_on_impuls        : impuls_1_sec;
	KO_off_impuls       : impuls_1_sec;
	PZK_1_on_impuls     : impuls_1_sec;
	PZK_1_off_impuls    : impuls_1_sec;

	p_min_reached       : BOOL;
	p_max_reached       : BOOL;
	use_kb_sensor       : BOOL;
	use_pzk1_mode       : BOOL;
END_VAR

VAR CONSTANT
	// Индексы настроек
	IDX_P_MIN           : INT := 1;
	IDX_P_MAX           : INT := 2;
	IDX_T_WAIT_1        : INT := 3;
	IDX_T_WAIT_2        : INT := 4;
	IDX_T_WAIT_3        : INT := 5;
	IDX_T_FAST          : INT := 6;
	IDX_T_TERMINATION   : INT := 7;
	IDX_KB_SENSOR       : INT := 8;
	IDX_PRESS_MODE      : INT := 9;

	// Режим источника признаков давления
	PRESS_SRC_ANALOG    : USINT := 0;
	PRESS_SRC_DI        : USINT := 1;
	PRESS_SRC_COMBINED  : USINT := 2;

	// Стадии автомата
	ST_IDLE             : WORD := 0;
	ST_PREPARE          : WORD := 1;
	ST_CHECK_TIGHTNESS  : WORD := 2;
	ST_SELECT_MODE      : WORD := 3;
	ST_WAIT_MIN         : WORD := 4;
	ST_WAIT_MAX         : WORD := 5;
	ST_WAIT_ACTUATORS   : WORD := 6;
	ST_EXIT             : WORD := 7;
	ST_FINISH           : WORD := 8;
	ST_PZK1_FILL        : WORD := 9;
	ST_PZK1_HOLD        : WORD := 10;
	ST_PZK1_WAIT_OPEN   : WORD := 11;
	ST_SUCCESS          : WORD := 15;
	ST_FAST             : WORD := 16;

	// Вспомогательные выдержки
	T_WAIT_KB_FEEDBACK  : DWORD := 6;
	T_PZK1_OPEN_MAX     : DWORD := 60;
	T_PZK1_OPEN_HOLD    : DWORD := 1;
END_VAR

// === IMPLEMENTATION ===

// Текущее время ПЛК
clock := SysTimeRTCGet(pResult := RTC_RESULT);

// Сброс импульсных команд по умолчанию
KB_on_impuls(CLK := FALSE, Q => KB_on);
KB_off_impuls(CLK := FALSE, Q => KB_off);
KO_on_impuls(CLK := FALSE, Q => KO_on);
KO_off_impuls(CLK := FALSE, Q => KO_off);
PZK_1_on_impuls(CLK := FALSE, Q => PZK_1_on);
PZK_1_off_impuls(CLK := FALSE, Q => PZK_1_off);

// Защёлка быстрого режима
fast_rs(SET := fast_auto, RESET1 := FALSE);

// Вспомогательные режимы
use_kb_sensor := REAL_TO_DWORD(Pressure_settings.Value[IDX_KB_SENSOR]) = 1;
use_pzk1_mode := REAL_TO_DWORD(Pressure_settings.Value[IDX_PRESS_MODE]) = 1;

// Определение признаков достигнутого давления
CASE pressure_source_mode OF
	PRESS_SRC_ANALOG:
		p_min_reached := Pressure_sensor_in >= Pressure_settings.Value[IDX_P_MIN];
		p_max_reached := Pressure_sensor_in >= Pressure_settings.Value[IDX_P_MAX];

	PRESS_SRC_DI:
		p_min_reached := P_min_active;
		p_max_reached := P_max_active;

	PRESS_SRC_COMBINED:
		p_min_reached := P_min_active OR (Pressure_sensor_in >= Pressure_settings.Value[IDX_P_MIN]);
		p_max_reached := P_max_active OR (Pressure_sensor_in >= Pressure_settings.Value[IDX_P_MAX]);

ELSE
	p_min_reached := Pressure_sensor_in >= Pressure_settings.Value[IDX_P_MIN];
	p_max_reached := Pressure_sensor_in >= Pressure_settings.Value[IDX_P_MAX];
END_CASE;

P_min_out := p_min_reached;
P_max_out := p_max_reached;


// Пропуск опрессовки оператором
IF skip AND NOT block THEN
	time_success := clock;
	Pressure_state_decoded.success := TRUE;
	Pressure_state_decoded.skipped := TRUE;
	case_counter := ST_EXIT;
END_IF;


// Сброс успешной опрессовки
abort_trig(CLK := abort, Q => abort_active);
IF abort_active THEN
	IF NOT abort_block AND Pressure_state_decoded.success THEN
		Pressure_state_decoded.success := FALSE;
		Pressure_state_decoded.aborted := TRUE;
		case_counter := ST_FINISH;
	ELSE
		Pressure_state_decoded.abort_forbidden := TRUE;
	END_IF
END_IF;


// Автоматическая отмена по истечении срока действия
IF Pressure_state_decoded.success THEN
	IF clock - time_success >= 3600 * REAL_TO_DWORD(Pressure_settings.Value[IDX_T_TERMINATION]) THEN
		Pressure_state_decoded.success := FALSE;
		Pressure_state_decoded.timeout_cancel := TRUE;
	END_IF
END_IF;


// Остановка текущей опрессовки
IF stop THEN
	case_counter := ST_EXIT;
END_IF;


// Старт опрессовки
Pressure_start_trig(CLK := start OR fast_rs.Q1, Q => start_active);

IF Pressure_start_trig.Q AND NOT block AND NOT Pressure_state_decoded.success AND NOT Pressure_state_decoded.in_progress THEN
	time_case_0 := clock;
	add_time := 0;

	// Сброс одноразовых сообщений перед новым циклом
	Pressure_state_decoded.skipped := FALSE;
	Pressure_state_decoded.kb_not_closed := FALSE;
	Pressure_state_decoded.pzk1_leak := FALSE;
	Pressure_state_decoded.timeout_cancel := FALSE;
	Pressure_state_decoded.aborted := FALSE;
	Pressure_state_decoded.msg_success := FALSE;
	Pressure_state_decoded.msg_fail := FALSE;
	Pressure_state_decoded.overpressure := FALSE;
	Pressure_state_decoded.leak := FALSE;
	Pressure_state_decoded.full_success := FALSE;
	Pressure_state_decoded.fast_success := FALSE;
	Pressure_state_decoded.abort_forbidden := FALSE;

	Pressure_state_decoded.in_progress := TRUE;
	case_counter := ST_PREPARE;
END_IF;


// Автомат стадий
CASE case_counter OF

	ST_PREPARE:
		// Закрываем КБ
		KB_on_impuls(CLK := TRUE, Q => KB_on);

		// В режиме через ПЗК-1 сначала закрываем ПЗК-1
		IF use_pzk1_mode THEN
			PZK_1_off_impuls(CLK := TRUE, Q => PZK_1_off);
		END_IF

		IF use_kb_sensor OR use_pzk1_mode THEN
			case_counter := ST_WAIT_ACTUATORS;
		ELSE
			case_counter := ST_CHECK_TIGHTNESS;
		END_IF


	ST_WAIT_ACTUATORS:
		IF time_wait(time_case_0, T_WAIT_KB_FEEDBACK) THEN
			add_time := clock - time_case_0;
			case_counter := ST_CHECK_TIGHTNESS;
		END_IF


	ST_CHECK_TIGHTNESS:
		// Если есть датчик КБ, проверяем, что КБ реально закрылся
		IF use_kb_sensor AND NOT KB_on_state THEN
			Pressure_state_decoded.kb_not_closed := TRUE;
			Pressure_state_decoded.msg_fail := TRUE;
			case_counter := ST_EXIT;
		END_IF

		// Ждём t_wait_1 и контролируем отсутствие самопроизвольного давления
		IF time_wait(time_case_0, add_time + REAL_TO_DWORD(Pressure_settings.Value[IDX_T_WAIT_1])) THEN
			IF p_max_reached OR p_min_reached THEN
				Pressure_state_decoded.pzk1_leak := TRUE;
				Pressure_state_decoded.msg_fail := TRUE;
				case_counter := ST_EXIT;
			ELSE
				IF use_pzk1_mode THEN
					PZK_1_on_impuls(CLK := TRUE, Q => PZK_1_on);
					case_counter := ST_PZK1_FILL;
				ELSE
					KO_on_impuls(CLK := TRUE, Q => KO_on);
					case_counter := ST_SELECT_MODE;
				END_IF
				add_time := clock - time_case_0;
			END_IF
		END_IF


	ST_SELECT_MODE:
		IF fast_rs.Q1 THEN
			case_counter := ST_FAST;
		ELSE
			case_counter := ST_WAIT_MIN;
		END_IF


	ST_WAIT_MIN:
		// За t_wait_2 нужно достичь минимума, но не превысить максимум
		IF time_wait(time_case_0, add_time + REAL_TO_DWORD(Pressure_settings.Value[IDX_T_WAIT_2])) THEN
			IF NOT p_min_reached OR p_max_reached THEN
				IF p_max_reached THEN
					Pressure_state_decoded.overpressure := TRUE;
				ELSE
					Pressure_state_decoded.leak := TRUE;
				END_IF
				Pressure_state_decoded.msg_fail := TRUE;
				case_counter := ST_EXIT;
			ELSE
				add_time := clock - time_case_0;
				case_counter := ST_WAIT_MAX;
			END_IF
		END_IF


	ST_WAIT_MAX:
		// За t_wait_3 ждём достижения максимального давления
		IF p_max_reached THEN
			case_counter := ST_SUCCESS;
		ELSE
			IF time_wait(time_case_0, add_time + REAL_TO_DWORD(Pressure_settings.Value[IDX_T_WAIT_3])) THEN
				Pressure_state_decoded.leak := TRUE;
				Pressure_state_decoded.msg_fail := TRUE;
				case_counter := ST_EXIT;
			END_IF
		END_IF


	ST_PZK1_FILL:
		// Ждём открытия ПЗК-1 или технологический таймаут
		IF time_wait(time_case_0, T_PZK1_OPEN_MAX + add_time) OR PZK_1_on_state THEN
			add_time := clock - time_case_0;
			case_counter := ST_PZK1_WAIT_OPEN;
		END_IF


	ST_PZK1_WAIT_OPEN:
		IF time_wait(time_case_0, T_PZK1_OPEN_HOLD + add_time) THEN
			PZK_1_off_impuls(CLK := TRUE, Q => PZK_1_off);
			add_time := clock - time_case_0;
			case_counter := ST_PZK1_HOLD;
		END_IF


	ST_PZK1_HOLD:
		// После закрытия ПЗК-1 проверяем удержание давления
		IF time_wait(time_case_0, add_time + REAL_TO_DWORD(Pressure_settings.Value[IDX_T_WAIT_3])) OR NOT p_max_reached THEN
			IF NOT p_max_reached THEN
				Pressure_state_decoded.leak := TRUE;
				Pressure_state_decoded.msg_fail := TRUE;
				case_counter := ST_EXIT;
			ELSE
				case_counter := ST_SUCCESS;
			END_IF
		END_IF


	ST_FAST:
		// Быстрая опрессовка - достаточно достигнуть минимального давления
		IF p_min_reached THEN
			case_counter := ST_SUCCESS;
		ELSE
			IF time_wait(time_case_0, add_time + REAL_TO_DWORD(Pressure_settings.Value[IDX_T_FAST])) THEN
				Pressure_state_decoded.msg_fail := TRUE;
				case_counter := ST_EXIT;
			END_IF
		END_IF


	ST_SUCCESS:
		Pressure_state_decoded.success := TRUE;
		Pressure_state_decoded.msg_success := TRUE;

		IF fast_rs.Q1 THEN
			Pressure_state_decoded.fast_success := TRUE;
		ELSE
			Pressure_state_decoded.full_success := TRUE;
		END_IF

		time_success := clock;
		case_counter := ST_EXIT;


	ST_EXIT:
		// Возврат клапанов в исходное состояние
		KO_off_impuls(CLK := TRUE, Q => KO_off);
		KB_off_impuls(CLK := TRUE, Q => KB_off);

		IF use_pzk1_mode THEN
			PZK_1_off_impuls(CLK := TRUE, Q => PZK_1_off);
		END_IF

		fast_rs(SET := FALSE, RESET1 := TRUE);
		case_counter := ST_FINISH;


	ST_FINISH:
		Pressure_state_decoded.in_progress := FALSE;
		case_counter := ST_IDLE;

END_CASE;


// Таймеры автосброса сообщений
clear_ton[1](IN := Pressure_state_decoded.skipped,          PT := T#1S);
clear_ton[2](IN := Pressure_state_decoded.kb_not_closed,    PT := T#1S);
clear_ton[3](IN := Pressure_state_decoded.pzk1_leak,        PT := T#1S);
clear_ton[4](IN := Pressure_state_decoded.timeout_cancel,   PT := T#1S);
clear_ton[5](IN := Pressure_state_decoded.aborted,          PT := T#1S);
clear_ton[6](IN := Pressure_state_decoded.msg_success,      PT := T#1S);
clear_ton[7](IN := Pressure_state_decoded.msg_fail,         PT := T#1S);
clear_ton[8](IN := Pressure_state_decoded.overpressure,     PT := T#1S);
clear_ton[9](IN := Pressure_state_decoded.leak,             PT := T#1S);
clear_ton[10](IN := Pressure_state_decoded.full_success,    PT := T#1S);
clear_ton[11](IN := Pressure_state_decoded.fast_success,    PT := T#1S);
clear_ton[12](IN := Pressure_state_decoded.abort_forbidden, PT := T#1S);
clear_ton[13](IN := Pressure_state_decoded.skip_forbidden,  PT := T#1S);

// Автосброс одноразовых сообщений
IF clear_ton[1].Q THEN Pressure_state_decoded.skipped := FALSE; END_IF
IF clear_ton[2].Q THEN Pressure_state_decoded.kb_not_closed := FALSE; END_IF
IF clear_ton[3].Q THEN Pressure_state_decoded.pzk1_leak := FALSE; END_IF
IF clear_ton[4].Q THEN Pressure_state_decoded.timeout_cancel := FALSE; END_IF
IF clear_ton[5].Q THEN Pressure_state_decoded.aborted := FALSE; END_IF
IF clear_ton[6].Q THEN Pressure_state_decoded.msg_success := FALSE; END_IF
IF clear_ton[7].Q THEN Pressure_state_decoded.msg_fail := FALSE; END_IF
IF clear_ton[8].Q THEN Pressure_state_decoded.overpressure := FALSE; END_IF
IF clear_ton[9].Q THEN Pressure_state_decoded.leak := FALSE; END_IF
IF clear_ton[10].Q THEN Pressure_state_decoded.full_success := FALSE; END_IF
IF clear_ton[11].Q THEN Pressure_state_decoded.fast_success := FALSE; END_IF
IF clear_ton[12].Q THEN Pressure_state_decoded.abort_forbidden := FALSE; END_IF
IF clear_ton[13].Q THEN Pressure_state_decoded.skip_forbidden := FALSE; END_IF


// Формирование DWORD из структуры
Pressure_state := 0;
Pressure_state.0 := Pressure_state_decoded.success;
Pressure_state.1 := Pressure_state_decoded.in_progress;
Pressure_state.2 := Pressure_state_decoded.skipped;
Pressure_state.3 := FALSE;
Pressure_state.4 := Pressure_state_decoded.kb_not_closed;
Pressure_state.5 := Pressure_state_decoded.pzk1_leak;
Pressure_state.6 := FALSE;
Pressure_state.7 := Pressure_state_decoded.skip_forbidden;
Pressure_state.8 := Pressure_state_decoded.timeout_cancel;
Pressure_state.9 := Pressure_state_decoded.aborted;
Pressure_state.10 := Pressure_state_decoded.msg_success;
Pressure_state.11 := Pressure_state_decoded.msg_fail;
Pressure_state.12 := Pressure_state_decoded.overpressure;
Pressure_state.13 := Pressure_state_decoded.leak;
Pressure_state.14 := Pressure_state_decoded.full_success;
Pressure_state.15 := Pressure_state_decoded.fast_success;
Pressure_state.16 := FALSE;
Pressure_state.17 := Pressure_state_decoded.abort_forbidden;