FUNCTION GetBurnerProtectIndex : WORD
VAR_INPUT
	burner_id : WORD;
	local_idx : WORD;
END_VAR
VAR
	protect_per_burner : WORD;
END_VAR

// === IMPLEMENTATION ===

(*
Горелки индексируются как 1..burner_quantity.
Текущие локальные индексы защит сохраняются 0-базными.
Возвращаемый глобальный индекс является 1-базным для плоских массивов Weintek/OPC UA.
*)
protect_per_burner := burner_protect_quantity + 1;
GetBurnerProtectIndex := (burner_id - 1) * protect_per_burner + local_idx + 1;