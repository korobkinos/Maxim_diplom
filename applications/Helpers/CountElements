FUNCTION CountElements : DWORD
VAR_INPUT
    arrData : ARRAY [*] OF BOOL;
    startIdx : DWORD;
    endIdx : DWORD;
END_VAR
VAR
    i : DWORD;
    count : DWORD;
END_VAR

// === IMPLEMENTATION ===

count := 0;
FOR i := startIdx TO endIdx DO
    IF arrData[i] = TRUE THEN
        count := count + 1;
    END_IF;
END_FOR

CountElements := count;