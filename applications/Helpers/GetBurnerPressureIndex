FUNCTION GetBurnerPressureIndex : WORD
VAR_INPUT
	burner_id : WORD;
	local_idx : WORD;
END_VAR

// === IMPLEMENTATION ===

(*
Горелки индексируются как 1..burner_quantity.
Текущие локальные индексы опрессовки сохраняются 0-базными.
Возвращаемый глобальный индекс является 1-базным для плоских массивов Weintek/OPC UA.
*)
GetBurnerPressureIndex := (burner_id - 1) * pressure_per_burner + local_idx + 1;
