FUNCTION TIME_WAIT : BOOL//Функция проверяет время ожидания в секундах
VAR_INPUT
	t_start:DWORD;//Время старта в секундах
	t_wait:DWORD;//Время ожидания в секундах
END_VAR
VAR
	RTC_RESULT:UDINT;
	clock:DWORD;										//Время ПЛК в формате секунд
END_VAR

// === IMPLEMENTATION ===

clock:=SysTimeRTCGet(pResult:=RTC_RESULT);
time_wait:=FALSE;
IF clock-t_start>=t_wait THEN
	time_wait:=TRUE;
END_IF