FUNCTION GetBurnerRegulatorIndex : WORD
VAR_INPUT
	burner_id : WORD;
	local_idx : WORD;
END_VAR

// === IMPLEMENTATION ===

(*
Горелки индексируются как 1..burner_quantity.
Текущие локальные индексы регуляторов сохраняются 0-базными.
Возвращаемый глобальный индекс является 1-базным для плоских массивов Weintek/OPC UA.
*)
GetBurnerRegulatorIndex := (burner_id - 1) * regulator_per_burner + local_idx + 1;