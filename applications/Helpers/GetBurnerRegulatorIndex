FUNCTION GetBurnerRegulatorIndex : WORD
VAR_INPUT
	burner_id : WORD;
	local_idx : WORD;
END_VAR

// === IMPLEMENTATION ===

(*
Маппинг локального индекса регулятора горелки в плоский глобальный индекс.
Вентиляция остается на уровне котла, AutoBurner и общая автопоследовательность не входят в FB_BURNER_UNIT.
*)
GetBurnerRegulatorIndex := (burner_id - 1) * regulator_per_burner + local_idx;