{attribute 'qualified_only'}
VAR_GLOBAL
	(*
	Плоская карта HMI/OPC UA для горелочных защит.
	Вложенные массивы не используются из-за ограничений Weintek/OPC UA.
	Карта зарезервирована для будущей миграции на несколько горелок.
	На текущую логику одной горелки карта пока не подключена.
	Глобальные индексы 1-базные и должны формироваться через GetBurnerProtectIndex.
	*)
	input          : ARRAY[1..total_burner_protect_quantity] OF BOOL;
	control        : ARRAY[1..total_burner_protect_quantity] OF BOOL;
	warning        : ARRAY[1..total_burner_protect_quantity] OF BOOL;
	alarm          : ARRAY[1..total_burner_protect_quantity] OF BOOL;
	execute_state  : ARRAY[1..total_burner_protect_quantity] OF BOOL;
	execute_set_cmd   : ARRAY[1..total_burner_protect_quantity] OF BOOL;
	execute_reset_cmd : ARRAY[1..total_burner_protect_quantity] OF BOOL;
END_VAR
