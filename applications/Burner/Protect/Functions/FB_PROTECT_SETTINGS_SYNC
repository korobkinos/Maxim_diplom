FUNCTION_BLOCK FB_PROTECT_SETTINGS_SYNC
VAR
	burner_id : WORD;
	local_idx : WORD;
	flat_idx : WORD;
	load_requested : BOOL;
	save_requested : BOOL;
	init_done : BOOL;
END_VAR

VAR CONSTANT
	protect_p_gas_item_idx : WORD := burner_protect_quantity + 1;
	protect_p_air_item_idx : WORD := burner_protect_quantity + 2;
	protect_flame_item_idx : WORD := burner_protect_quantity + 3;
END_VAR

// === IMPLEMENTATION ===

IF NOT init_done THEN
	FOR burner_id := 1 TO burner_quantity DO
		FOR local_idx := 0 TO burner_protect_quantity - 1 DO
			flat_idx := (burner_id - 1) * burner_protect_quantity + local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_protect_quantity) THEN
				GVL_BURNER_PROTECT_HMI.hmi_protect_enable[flat_idx] := SETTINGS.protect_settings[burner_id].protect[local_idx].enable;
			END_IF;

			flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
				GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[local_idx].delay_time;
			END_IF;
		END_FOR;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_p_gas_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[0].p_gas_control_delay;
		END_IF;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_p_air_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[0].p_air_control_delay;
		END_IF;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_flame_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[0].flame_control_delay;
		END_IF;
	END_FOR;
	init_done := TRUE;
END_IF;

load_requested := GVL_BURNER_PROTECT_HMI.hmi_load_settings;
save_requested := GVL_BURNER_PROTECT_HMI.hmi_save_settings;

IF load_requested THEN
	FOR burner_id := 1 TO burner_quantity DO
		FOR local_idx := 0 TO burner_protect_quantity - 1 DO
			flat_idx := (burner_id - 1) * burner_protect_quantity + local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_protect_quantity) THEN
				GVL_BURNER_PROTECT_HMI.hmi_protect_enable[flat_idx] := SETTINGS.protect_settings[burner_id].protect[local_idx].enable;
			END_IF;

			flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
				GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[local_idx].delay_time;
			END_IF;
		END_FOR;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_p_gas_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[0].p_gas_control_delay;
		END_IF;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_p_air_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[0].p_air_control_delay;
		END_IF;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_flame_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx] := SETTINGS.protect_settings[burner_id].protect[0].flame_control_delay;
		END_IF;
	END_FOR;
	GVL_BURNER_PROTECT_HMI.hmi_load_settings := FALSE;
ELSIF save_requested THEN
	FOR burner_id := 1 TO burner_quantity DO
		FOR local_idx := 0 TO burner_protect_quantity - 1 DO
			flat_idx := (burner_id - 1) * burner_protect_quantity + local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_protect_quantity) THEN
				SETTINGS.protect_settings[burner_id].protect[local_idx].enable := GVL_BURNER_PROTECT_HMI.hmi_protect_enable[flat_idx];
			END_IF;

			flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
				SETTINGS.protect_settings[burner_id].protect[local_idx].delay_time := GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx];
			END_IF;
		END_FOR;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_p_gas_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			FOR local_idx := 0 TO burner_protect_quantity - 1 DO
				SETTINGS.protect_settings[burner_id].protect[local_idx].p_gas_control_delay := GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx];
			END_FOR;
		END_IF;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_p_air_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			FOR local_idx := 0 TO burner_protect_quantity - 1 DO
				SETTINGS.protect_settings[burner_id].protect[local_idx].p_air_control_delay := GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx];
			END_FOR;
		END_IF;

		flat_idx := (burner_id - 1) * protect_delay_hmi_item_quantity + protect_flame_item_idx;
		IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * protect_delay_hmi_item_quantity) THEN
			FOR local_idx := 0 TO burner_protect_quantity - 1 DO
				SETTINGS.protect_settings[burner_id].protect[local_idx].flame_control_delay := GVL_BURNER_PROTECT_HMI.hmi_protect_delay_flat[flat_idx];
			END_FOR;
		END_IF;
	END_FOR;
	GVL_BURNER_PROTECT_HMI.hmi_save_settings := FALSE;
END_IF;
