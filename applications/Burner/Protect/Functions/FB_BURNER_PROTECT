FUNCTION_BLOCK FB_BURNER_PROTECT
VAR_INPUT
	burner_id : WORD;
	enable    : BOOL;
END_VAR

VAR_IN_OUT
	protect_data   : ST_BURNER_PROTECT_DATA;
	burner_data    : ST_BURNER_DATA;
	valve_data     : ST_BURNER_VALVE_DATA;
	ignition_data  : ST_BURNER_IGNITION_DATA;
	pressure_data  : ST_BURNER_PRESSURE_DATA;
END_VAR

VAR
	protect                : ARRAY[0..burner_protect_quantity] OF protect_singl;
	protect_on_off         : ARRAY[0..burner_protect_quantity] OF protect_on_off_singl;
	p_gas_control_delay_ton: TON;
	p_air_control_delay_ton: TON;
	flame_control_delay_ton: TON;
	pzk_2_ft               : F_TRIG;
	protect_alarm_tmp      : ARRAY[0..burner_protect_quantity] OF BOOL;
	protect_warning_tmp    : ARRAY[0..burner_protect_quantity] OF BOOL;
	signal_value           : BOOL;
	control_value          : BOOL;
	alarm_value            : BOOL;
	warning_value          : BOOL;
	cmd_execute_set        : BOOL;
	cmd_execute_reset      : BOOL;
	cmd_protect_enable     : BOOL;
	pilot_p_control_current: BOOL;
	case_counter           : WORD;
	i                      : WORD;
	p_gas_control_delay_cfg: REAL;
	p_air_control_delay_cfg: REAL;
	flame_control_delay_cfg: REAL;
	protect_delay_cfg      : REAL;
	effective_test_mode    : BOOL;
END_VAR

VAR CONSTANT
	PC_PZK_1_P         : WORD := 0;
	PC_PZK_2_P         : WORD := 1;
	PC_IGNITION_P      : WORD := 2;
	PC_PILOT_P         : WORD := 3;
	PC_AIR_BURNER_P    : WORD := 4;
	PC_GAS_BURNER_P    : WORD := 5;
	PC_VENT_BURNER_P   : WORD := 6;
	PC_GAS_BURNER_UP_P : WORD := 7;
END_VAR

// === IMPLEMENTATION ===

IF NOT enable THEN
	FOR i := 0 TO burner_protect_quantity DO
		protect_data.protect_control[i] := FALSE;
		protect_data.protect_warning[i] := FALSE;
		protect_data.protect_alarm[i] := FALSE;
		protect_data.execute_state[i] := FALSE;
	END_FOR;
	protect_data.main_warning := FALSE;
	protect_data.main_alarm := FALSE;
	protect_data.state := 0;
ELSE
	effective_test_mode := (burner_id >= 1) AND (burner_id <= burner_quantity) AND SETTINGS.burner_test_mode[burner_id];

	p_gas_control_delay_cfg := protect_data.p_gas_control_delay;
	p_air_control_delay_cfg := protect_data.p_air_control_delay;
	flame_control_delay_cfg := protect_data.flame_control_delay;

	p_air_control_delay_ton(
		IN := burner_data.boiler_run,
		PT := REAL_TO_TIME(p_air_control_delay_cfg * 1000)
	);

	p_gas_control_delay_ton(
		IN := burner_data.boiler_run,
		PT := REAL_TO_TIME(p_gas_control_delay_cfg * 1000)
	);

	flame_control_delay_ton(
		IN := burner_data.burner_start OR burner_data.boiler_run,
		PT := REAL_TO_TIME(flame_control_delay_cfg * 1000)
	);

	pzk_2_ft(CLK := valve_data.control_out[pzk_2]);

	pilot_p_control_current := protect_data.protect_control[PC_PILOT_P];
	IF valve_data.control_out[pzk_2] AND flame_control_delay_ton.Q THEN
		pilot_p_control_current := TRUE;
	END_IF;
	IF pzk_2_ft.Q OR protect_data.protect_alarm[PC_PILOT_P] THEN
		pilot_p_control_current := FALSE;
	END_IF;
	IF effective_test_mode THEN
		pilot_p_control_current := TRUE;
	END_IF;
	cmd_protect_enable := protect_data.protect_enable[PC_PILOT_P];
	IF NOT cmd_protect_enable THEN
		pilot_p_control_current := FALSE;
	END_IF;

	FOR i := 0 TO burner_protect_quantity DO
		signal_value := protect_data.protect_input[i];
		control_value := protect_data.protect_control[i];
		case_counter := i;

		CASE case_counter OF
			PC_PZK_1_P:
				signal_value := valve_data.closed_state[pzk_1];
			PC_PZK_2_P:
				signal_value := valve_data.closed_state[pzk_2];
			PC_IGNITION_P:
				signal_value := valve_data.closed_state[ignit] OR NOT valve_data.open_state[ignit];
			PC_PILOT_P:
				signal_value := valve_data.closed_state[pilot] OR NOT valve_data.open_state[pilot];
			PC_VENT_BURNER_P:
				signal_value := valve_data.closed_state[vent_burner] OR NOT valve_data.open_state[vent_burner];
		END_CASE;

		CASE case_counter OF
			PC_IGNITION_P:
				IF valve_data.open_state[pzk_1] AND valve_data.open_state[kz] AND burner_data.burner_start THEN
					control_value := TRUE;
				END_IF;
				IF pilot_p_control_current OR pzk_2_ft.Q THEN
					control_value := FALSE;
				END_IF;
			PC_AIR_BURNER_P:
				IF p_air_control_delay_ton.Q THEN
					control_value := TRUE;
				END_IF;
				IF pzk_2_ft.Q OR valve_data.closed_state[pzk_2] THEN
					control_value := FALSE;
				END_IF;
			PC_GAS_BURNER_P:
				IF p_gas_control_delay_ton.Q THEN
					control_value := TRUE;
				END_IF;
				IF pzk_2_ft.Q OR valve_data.closed_state[pzk_2] THEN
					control_value := FALSE;
				END_IF;
			PC_GAS_BURNER_UP_P:
				IF p_gas_control_delay_ton.Q THEN
					control_value := TRUE;
				END_IF;
				IF pzk_2_ft.Q OR valve_data.closed_state[pzk_2] THEN
					control_value := FALSE;
				END_IF;
			PC_PILOT_P:
				IF valve_data.control_out[pzk_2] AND flame_control_delay_ton.Q THEN
					control_value := TRUE;
				END_IF;
				IF pzk_2_ft.Q OR protect_data.protect_alarm[PC_PILOT_P] THEN
					control_value := FALSE;
				END_IF;
			PC_PZK_1_P:
				IF ((burner_data.burner_start OR burner_data.boiler_run) AND valve_data.open_state[pzk_1]) OR effective_test_mode THEN
					control_value := TRUE;
				END_IF;
				IF valve_data.down_out[pzk_1] THEN
					control_value := FALSE;
				END_IF;
			PC_PZK_2_P:
				IF ((burner_data.burner_start OR burner_data.boiler_run) AND valve_data.open_state[pzk_2]) OR effective_test_mode THEN
					control_value := TRUE;
				END_IF;
				IF valve_data.down_out[pzk_2] THEN
					control_value := FALSE;
				END_IF;
		END_CASE;

		IF effective_test_mode THEN
			control_value := TRUE;
		END_IF;

		cmd_execute_set := protect_data.execute_set_cmd[i];
		cmd_execute_reset := protect_data.execute_reset_cmd[i];
		cmd_protect_enable := protect_data.protect_enable[i];

		protect_on_off[i](
			MAN_ON := cmd_execute_set,
			MAN_OFF := cmd_execute_reset,
			TERMINATE_TIME := 0,
			Zachita_vvedena := protect_data.execute_state[i]
		);

		alarm_value := FALSE;
		warning_value := FALSE;
		protect_delay_cfg := protect_data.protect_delay_time[i];

		protect[i](
			Signal_groupe_param := signal_value,
			CTRL_ON := control_value,
			PROTECT_EXECUTE := protect_data.execute_state[i],
			Sbros_Av := burner_data.burner_start OR burner_data.start_cmd,
			delay_time := protect_delay_cfg,
			PROTECT_ACTIVE => alarm_value,
			ALARM_ACTIVE => warning_value
		);

		IF NOT cmd_protect_enable THEN
			control_value := FALSE;
			alarm_value := FALSE;
			warning_value := FALSE;
		END_IF;

		protect_data.protect_input[i] := signal_value;
		protect_data.protect_control[i] := control_value;
		protect_data.protect_alarm[i] := alarm_value;
		protect_data.protect_warning[i] := warning_value;
		protect_alarm_tmp[i] := alarm_value;
		protect_warning_tmp[i] := warning_value;
	END_FOR;

	protect_data.main_alarm := DWORD_TO_BOOL(
		CountElements(
			arrData := protect_alarm_tmp,
			startIdx := 0,
			endIdx := burner_protect_quantity
		)
	);

	protect_data.main_warning := DWORD_TO_BOOL(
		CountElements(
			arrData := protect_warning_tmp,
			startIdx := 0,
			endIdx := burner_protect_quantity
		)
	);

	protect_data.state := 0;
END_IF;
