FUNCTION_BLOCK protect_singl
VAR_INPUT
	Signal_groupe_param: BOOL; //Сигнал "груп.параметр "
	CTRL_ON: BOOL;// Включить контроль "груп.параметр "
	PROTECT_EXECUTE: BOOL;// Защита введена (0-введена!)
	Sbros_Av: BOOL;//Сброс аварии
END_VAR
VAR_OUTPUT
	PROTECT_ACTIVE: BOOL;//Команда выдачи защиты с учетом задержки(1-аварийное состояние флага защиты) 
    ALARM_ACTIVE: BOOL;   //Аварийное сообщение Групповой параметр защиты
END_VAR
VAR_IN_OUT
   delay_time:REAL;//Задержка включения выходного сигнала в сек
END_VAR
VAR
	//VALVE_CONTROL_ON:ARRAY[1..burner_quantity] OF BOOL;//Активно управление клапанами
	PROTECT_TON: TON;
	PROTECT_TON_ACTIVE: BOOL;
	PROTECT_RS: RS;
	ALARM_TON: TON;
	ALARM_TON_ACTIVE: BOOL;
	ALARM_RS: RS;
	control_r_trig:r_trig;
	execute_r_trig:r_trig;
	//counter:WORD;
END_VAR

// === IMPLEMENTATION ===

//Определение постановки на контроль или ввода для сброса аварии
control_r_trig(	clk:= CTRL_ON);
execute_r_trig(	clk:= NOT PROTECT_EXECUTE);

//Определение задержки
PROTECT_TON(IN:=Signal_groupe_param AND CTRL_ON AND NOT PROTECT_EXECUTE,
			PT:=REAL_TO_TIME(delay_time*1000),
			Q=>PROTECT_TON_ACTIVE);
//Действие на арматуру
PROTECT_RS(	SET:=PROTECT_TON_ACTIVE,
			RESET1:=Sbros_Av OR control_r_trig.Q OR execute_r_trig.Q,
			Q1=>PROTECT_ACTIVE);
//Определение задержки
ALARM_TON(	IN:=Signal_groupe_param AND CTRL_ON AND PROTECT_EXECUTE,
			PT:=REAL_TO_TIME(delay_time*1000),
			Q=>ALARM_TON_ACTIVE);
//Действие на лампу
ALARM_RS(	SET:=ALARM_TON_ACTIVE,
			RESET1:=Sbros_Av OR control_r_trig.Q OR execute_r_trig.Q,
			Q1=>ALARM_ACTIVE);