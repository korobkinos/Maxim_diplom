TYPE ST_BURNER_PROTECT_DATA :
STRUCT
	// Внутренняя память для будущего FB_BURNER_UNIT.
	// К текущей логике одной горелки пока не подключено.
	// Локальная 0-базная индексация внутренних массивов сохранена (арматура 0..counter_armature, защиты 0..burner_protect_quantity, регуляторы 0..PID_quantity).
	// Визуализация и OPC UA используют отдельные плоские карты GVL_BURNER_*.
	// Вентиляция остается логикой уровня котла и в эти типы не входит.
	// Логика AutoBurner и общая автопоследовательность здесь не описываются.
	main_alarm        : BOOL;
	main_warning      : BOOL;
	protect_input     : ARRAY[0..burner_protect_quantity] OF BOOL;
	protect_control   : ARRAY[0..burner_protect_quantity] OF BOOL;
	protect_enable    : ARRAY[0..burner_protect_quantity] OF BOOL;
	protect_warning   : ARRAY[0..burner_protect_quantity] OF BOOL;
	protect_alarm     : ARRAY[0..burner_protect_quantity] OF BOOL;
	execute_state     : ARRAY[0..burner_protect_quantity] OF BOOL;
	execute_set_cmd   : ARRAY[0..burner_protect_quantity] OF BOOL;
	execute_reset_cmd : ARRAY[0..burner_protect_quantity] OF BOOL;
	state             : DWORD;
END_STRUCT
END_TYPE
