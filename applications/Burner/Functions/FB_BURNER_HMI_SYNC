FUNCTION_BLOCK FB_BURNER_HMI_SYNC
VAR_INPUT
	burner_id : WORD;
	enable    : BOOL;
END_VAR

VAR_IN_OUT
	burner_data    : ST_BURNER_DATA;
	pressure_data  : ST_BURNER_PRESSURE_DATA;
	ignition_data  : ST_BURNER_IGNITION_DATA;
	protect_data   : ST_BURNER_PROTECT_DATA;
	regulator_data : ST_BURNER_REGULATOR_DATA;
	valve_data     : ST_BURNER_VALVE_DATA;
END_VAR

VAR
	local_idx  : WORD;
	global_idx : WORD;
END_VAR

// === IMPLEMENTATION ===

(*
Слой синхронизации связывает только внутреннюю память будущего FB_BURNER_UNIT
с плоскими картами GVL_BURNER_* для HMI/OPC UA.
Этот блок не выполняет алгоритмы горелки.
На текущую работу одной горелки не влияет, так как BURNERS_MANAGER не подключен в MAIN.
Вентиляция остается логикой уровня котла и в синхронизацию не входит.
Логика AutoBurner и цепочка "вентиляция -> опрессовка -> розжиг" намеренно исключены.
*)

IF enable THEN
	burner_data.start_cmd := GVL_BURNERS.start_cmd[burner_id];
	burner_data.stop_cmd := GVL_BURNERS.stop_cmd[burner_id];
	burner_data.auto_mode := GVL_BURNERS.auto_mode[burner_id];
	burner_data.manual_mode := GVL_BURNERS.manual_mode[burner_id];
	regulator_data.load_setpoint := GVL_BURNERS.load_setpoint[burner_id];

	pressure_data.settings_local.VALUE[1] := GVL_BURNER_PRESSURE.cfg_p_min[burner_id];
	pressure_data.settings_local.VALUE[2] := GVL_BURNER_PRESSURE.cfg_p_max[burner_id];
	pressure_data.settings_local.VALUE[3] := GVL_BURNER_PRESSURE.cfg_t_wait_1[burner_id];
	pressure_data.settings_local.VALUE[4] := GVL_BURNER_PRESSURE.cfg_t_wait_2[burner_id];
	pressure_data.settings_local.VALUE[5] := GVL_BURNER_PRESSURE.cfg_t_wait_3[burner_id];
	pressure_data.settings_local.VALUE[6] := GVL_BURNER_PRESSURE.cfg_t_fast[burner_id];
	pressure_data.settings_local.VALUE[7] := GVL_BURNER_PRESSURE.cfg_t_termination[burner_id];
	pressure_data.settings_local.VALUE[8] := GVL_BURNER_PRESSURE.cfg_kb_sensor[burner_id];
	pressure_data.settings_local.VALUE[9] := GVL_BURNER_PRESSURE.cfg_press_mode[burner_id];
	pressure_data.pressure_ai_idx := GVL_BURNER_PRESSURE.cfg_pressure_ai_idx[burner_id];

	ignition_data.settings_local.VALUE[1] := GVL_BURNER_IGNITION.cfg_mode[burner_id];
	ignition_data.settings_local.VALUE[2] := GVL_BURNER_IGNITION.cfg_repeat[burner_id];
	ignition_data.settings_local.VALUE[3] := GVL_BURNER_IGNITION.cfg_t_ignition[burner_id];
	ignition_data.settings_local.VALUE[4] := GVL_BURNER_IGNITION.cfg_t_gas_spark[burner_id];
	ignition_data.settings_local.VALUE[5] := GVL_BURNER_IGNITION.cfg_t_flame_check[burner_id];
	ignition_data.flame_feedback_idx := GVL_BURNER_IGNITION.cfg_flame_feedback_idx[burner_id];
END_IF;

FOR local_idx := 0 TO counter_armature DO
	global_idx := GetBurnerValveIndex(burner_id := burner_id, local_idx := local_idx);

	IF enable THEN
		valve_data.up[local_idx] := GVL_BURNER_VALVE.up[global_idx];
		valve_data.down[local_idx] := GVL_BURNER_VALVE.down[global_idx];
		valve_data.open[local_idx] := GVL_BURNER_VALVE.open[global_idx];
		valve_data.closed[local_idx] := GVL_BURNER_VALVE.closed[global_idx];
		valve_data.stop[local_idx] := GVL_BURNER_VALVE.stop[global_idx];
		valve_data.block[local_idx] := GVL_BURNER_VALVE.block[global_idx];
		valve_data.set_special[local_idx] := GVL_BURNER_VALVE.set_special[global_idx];
		valve_data.set_auto[local_idx] := GVL_BURNER_VALVE.set_auto[global_idx];
		valve_data.set_manual[local_idx] := GVL_BURNER_VALVE.set_manual[global_idx];
		valve_data.imitation_mode[local_idx] := GVL_BURNER_VALVE.imitation_mode[global_idx];
		valve_data.open_state_di[local_idx] := GVL_BURNER_VALVE.open_state_di[global_idx];
		valve_data.closed_state_di[local_idx] := GVL_BURNER_VALVE.closed_state_di[global_idx];
		valve_data.special_state_di[local_idx] := GVL_BURNER_VALVE.special_state_di[global_idx];
	END_IF;

	GVL_BURNER_VALVE.open_state[global_idx] := valve_data.open_state[local_idx];
	GVL_BURNER_VALVE.closed_state[global_idx] := valve_data.closed_state[local_idx];
	GVL_BURNER_VALVE.error_out[global_idx] := valve_data.error_out[local_idx];
	GVL_BURNER_VALVE.control_out[global_idx] := valve_data.control_out[local_idx];
	GVL_BURNER_VALVE.move_out[global_idx] := valve_data.move_out[local_idx];
	GVL_BURNER_VALVE.state[global_idx] := valve_data.state[local_idx];
	GVL_BURNER_VALVE.percent[global_idx] := valve_data.percent[local_idx];
END_FOR;

FOR local_idx := 0 TO burner_protect_quantity DO
	global_idx := GetBurnerProtectIndex(burner_id := burner_id, local_idx := local_idx);

	IF enable THEN
		protect_data.protect_input[local_idx] := GVL_BURNER_PROTECT.input[global_idx];
		protect_data.protect_control[local_idx] := GVL_BURNER_PROTECT.control[global_idx];
		protect_data.protect_enable[local_idx] := GVL_BURNER_PROTECT.protect_enable[global_idx];
		protect_data.execute_set_cmd[local_idx] := GVL_BURNER_PROTECT.execute_set_cmd[global_idx];
		protect_data.execute_reset_cmd[local_idx] := GVL_BURNER_PROTECT.execute_reset_cmd[global_idx];
	END_IF;

	GVL_BURNER_PROTECT.warning[global_idx] := protect_data.protect_warning[local_idx];
	GVL_BURNER_PROTECT.alarm[global_idx] := protect_data.protect_alarm[local_idx];
	GVL_BURNER_PROTECT.execute_state[global_idx] := protect_data.execute_state[local_idx];
END_FOR;

FOR local_idx := 0 TO PID_quantity DO
	global_idx := GetBurnerRegulatorIndex(burner_id := burner_id, local_idx := local_idx);

	IF enable THEN
		regulator_data.reg_valve[local_idx].auto_set := GVL_BURNER_REGULATOR.auto_set[global_idx];
		regulator_data.reg_valve[local_idx].man_set := GVL_BURNER_REGULATOR.man_set[global_idx];
		regulator_data.reg_valve[local_idx].setpoint := GVL_BURNER_REGULATOR.setpoint[global_idx];
	END_IF;

	GVL_BURNER_REGULATOR.up_out[global_idx] := regulator_data.reg_valve[local_idx].up_out;
	GVL_BURNER_REGULATOR.down_out[global_idx] := regulator_data.reg_valve[local_idx].down_out;
	GVL_BURNER_REGULATOR.feedback[global_idx] := regulator_data.reg_valve[local_idx].feedback;
	GVL_BURNER_REGULATOR.output[global_idx] := regulator_data.reg_valve[local_idx].output;
	GVL_BURNER_REGULATOR.alarm[global_idx] := regulator_data.reg_valve[local_idx].alarm;
	GVL_BURNER_REGULATOR.warning[global_idx] := regulator_data.reg_valve[local_idx].warning;
END_FOR;

GVL_BURNERS.load_feedback[burner_id] := regulator_data.load_feedback;
