FUNCTION_BLOCK burner_singl
VAR_INPUT
	start: BOOL;                        // Старт горелки в автоматическом режиме
	start_block: BOOL;                  // Блокировка пуска горелки
	stop: BOOL;                         // Стоп горелки
	stop_block: BOOL;                   // Блокировка стопа горелки

	ignition_flame: BOOL;               // Пламя запальника
	ignition_ready: BOOL;               // Запальник запущен
	ignition_error: BOOL;               // Ошибка розжига запальника

	pilot_flame: BOOL;                  // Пламя горелки
	pilot_protect_on: BOOL;             // Включён контроль пламени горелки

	PZK_1_open: BOOL;                   // ПЗК-1 открыт
	PZK_2_open: BOOL;                   // ПЗК-2 открыт
	kz_open: BOOL;                      // Есть команда управления на клапан запальника

	shiber_open_state: BOOL;            // Шибер воздуха открыт
	shiber_closed_state: BOOL;          // Шибер воздуха закрыт
	shiber_error: BOOL;                 // Ошибка шибера воздуха

	GAZ_shiber_open_state: BOOL;        // Заслонка газа открыта
	GAZ_shiber_closed_state: BOOL;      // Заслонка газа закрыта
	GAZ_shiber_error: BOOL;             // Ошибка заслонки газа

	ventilator_state: BOOL;             // Состояние вентилятора горелки

	burner_control_settings: burner_settings; // Настройки блока горелки
	boiler_alarm: BOOL;                 // Котловая авария (ШВ не закрываем)
END_VAR

VAR_OUTPUT
	PZK_1_on: BOOL;                     // Команда открыть ПЗК-1
	PZK_1_off: BOOL;                    // Команда закрыть ПЗК-1
	PZK_2_on: BOOL;                     // Команда открыть ПЗК-2
	PZK_2_off: BOOL;                    // Команда закрыть ПЗК-2

	shiber_open_out: BOOL;              // Открыть шибер воздуха
	shiber_closed_out: BOOL;            // Закрыть шибер воздуха
	shiber_auto: BOOL;                  // Шибер воздуха в автомат
	shiber_manual: BOOL;                // Шибер воздуха в ручной

	GAZ_shiber_open_out: BOOL;          // Открыть заслонку газа
	GAZ_shiber_closed_out: BOOL;        // Закрыть заслонку газа
	GAZ_shiber_auto: BOOL;              // Заслонка газа в автомат / на минимальную мощность
	GAZ_shiber_manual: BOOL;            // Заслонка газа в ручной

	Ignition_start: BOOL;               // Запуск блока запальника
	Ignition_stop: BOOL;                // Стоп блока запальника

	ventilator_start: BOOL;             // Запуск вентилятора горелки
	ventilator_stop: BOOL;              // Останов вентилятора горелки

	burner_work: BOOL;                  // Горелка в работе
	burner_state: DWORD;                // Биты состояния блока
	// 0  - Запущена процедура розжига горелки
	// 2  - Не включился вентилятор
	// 3  - Горелка остановлена
	// 4  - ПЗК-1 не открылся
	// 5  - Горелка в работе
	// 7  - Долго нет пламени горелки
	// 31 - Процедура розжига остановлена
END_VAR

VAR
	RTC_RESULT: UDINT;
	clock: DWORD;                           // Время ПЛК в секундах
	case_counter: WORD;                     // Текущая стадия автомата
	burner_start_time: DWORD;               // Время старта горелки
	add_time: DWORD;                        // Добавленное время к моменту старта

	impuls_PZK_1_start: impuls_1_sec;
	impuls_PZK_1_stop: impuls_1_sec;
	impuls_PZK_2_start: impuls_1_sec;
	impuls_PZK_2_stop: impuls_1_sec;

	impuls_shiber_open: impuls_1_sec;
	impuls_shiber_closed: impuls_1_sec;
	impuls_shiber_auto: impuls_1_sec;
	impuls_shiber_manual: impuls_1_sec;

	impuls_GAZ_shiber_open: impuls_1_sec;
	impuls_GAZ_shiber_closed: impuls_1_sec;
	impuls_GAZ_shiber_auto: impuls_1_sec;
	impuls_GAZ_shiber_manual: impuls_1_sec;

	impuls_ignition_start: impuls_1_sec;
	impuls_ignition_stop: impuls_1_sec;

	impuls_ventilator_start: impuls_1_sec;
	impuls_ventilator_stop: impuls_1_sec;

	start_trig: R_TRIG;                     // Момент старта горелки
	stop_trig: R_TRIG;                      // Момент остановки горелки

	clear_ton: ARRAY[1..6] OF TON;
END_VAR

VAR CONSTANT
	// Настройки блока горелки
	IDX_PZK1_OPEN_WAIT   : INT := 1;   // Время ожидания открытия ПЗК-1, сек
	IDX_AIR_DELAY        : INT := 2;   // Время задержки открытия ШВ относительно ГЗ, сек
	IDX_DAMPER_MODE      : INT := 3;   // Режим открытия ГЗ и ШВ
	IDX_SHIBER_STOP_MODE : INT := 4;   // Положение ШВ при останове горелки
	IDX_FLAME_WAIT       : INT := 5;   // Время ожидания появления пламени горелки
	IDX_IGNITION_WAIT    : INT := 6;   // Время ожидания готовности запальника, сек

	// Стадии автомата розжига горелки
	ST_IDLE                : WORD := 0;   // Ожидание / нет активного процесса
	ST_CLOSE_DAMPERS       : WORD := 1;   // Закрытие заслонки газа и шибера воздуха
	ST_WAIT_DAMPERS_CLOSED : WORD := 2;   // Ожидание закрытия заслонки газа и шибера воздуха
	ST_START_FAN           : WORD := 3;   // Пуск вентилятора и ожидание подтверждения
	ST_WAIT_PZK1_OPEN      : WORD := 4;   // Ожидание открытия ПЗК-1
	ST_START_IGNITION      : WORD := 5;   // Запуск запальника
	ST_WAIT_IGNITION_READY : WORD := 6;   // Ожидание готовности запальника
	ST_OPEN_PZK2           : WORD := 7;   // Открытие ПЗК-2
	ST_WAIT_FLAME          : WORD := 8;   // Ожидание появления пламени горелки
	ST_GAS_DAMPER_ACTION   : WORD := 9;   // Операции с заслонкой газа
	ST_WAIT_DAMPERS_OPEN   : WORD := 10;  // Ожидание открытия шибера воздуха и заслонки газа
	ST_BURNER_WORK         : WORD := 11;  // Горелка в работе
	ST_WAIT_GAS_DELAY      : WORD := 12;  // Пауза между пуском заслонки газа и шибера воздуха
	ST_AIR_SHIBER_ACTION   : WORD := 13;  // Операции с шибером воздуха
	ST_STOP_BURNER         : WORD := 15;  // Останов горелки / выход из процедуры розжига
END_VAR

// === IMPLEMENTATION ===

// Часы реального времени
clock := SysTimeRTCGet(pResult := RTC_RESULT);

// Определение момента старта горелки
start_trig(CLK := start AND NOT start_block);

// Определение момента стопа горелки
stop_trig(CLK := stop AND NOT stop_block);

// Сброс импульсных выходов по умолчанию
impuls_ignition_start(CLK := FALSE, Q => Ignition_start);
impuls_ignition_stop(CLK := FALSE, Q => Ignition_stop);

impuls_ventilator_start(CLK := FALSE, Q => ventilator_start);
impuls_ventilator_stop(CLK := FALSE, Q => ventilator_stop);

impuls_PZK_1_start(CLK := FALSE, Q => PZK_1_on);
impuls_PZK_1_stop(CLK := FALSE, Q => PZK_1_off);
impuls_PZK_2_start(CLK := FALSE, Q => PZK_2_on);
impuls_PZK_2_stop(CLK := FALSE, Q => PZK_2_off);

impuls_shiber_open(CLK := FALSE, Q => shiber_open_out);
impuls_shiber_closed(CLK := FALSE, Q => shiber_closed_out);
impuls_shiber_auto(CLK := FALSE, Q => shiber_auto);
impuls_shiber_manual(CLK := FALSE, Q => shiber_manual);

impuls_GAZ_shiber_open(CLK := FALSE, Q => GAZ_shiber_open_out);
impuls_GAZ_shiber_closed(CLK := FALSE, Q => GAZ_shiber_closed_out);
impuls_GAZ_shiber_auto(CLK := FALSE, Q => GAZ_shiber_auto);
impuls_GAZ_shiber_manual(CLK := FALSE, Q => GAZ_shiber_manual);

// Старт горелки
IF start_trig.Q THEN
	burner_state.0 := TRUE;            // Процедура розжига запущена
	add_time := 0;
	burner_start_time := clock;
	case_counter := ST_CLOSE_DAMPERS;
END_IF;

// Стоп горелки
IF stop_trig.Q THEN
	case_counter := ST_STOP_BURNER;
END_IF;

// Выключаем запальник после постановки на контроль пламени горелки
IF pilot_protect_on AND kz_open THEN
	impuls_ignition_stop(CLK := TRUE, Q => Ignition_stop);
END_IF;


// Автомат стадий
CASE case_counter OF

	ST_CLOSE_DAMPERS:
		// Закрываем заслонку газа и шибер воздуха
		impuls_GAZ_shiber_manual(CLK := TRUE, Q => GAZ_shiber_manual);
		impuls_GAZ_shiber_closed(CLK := TRUE, Q => GAZ_shiber_closed_out);

		impuls_shiber_manual(CLK := TRUE, Q => shiber_manual);
		impuls_shiber_closed(CLK := TRUE, Q => shiber_closed_out);

		case_counter := ST_WAIT_DAMPERS_CLOSED;


	ST_WAIT_DAMPERS_CLOSED:
		// Ожидаем закрытия шибера воздуха и заслонки газа
		IF NOT shiber_closed_state THEN
			IF shiber_error THEN
				case_counter := ST_STOP_BURNER;
			END_IF;
		END_IF;

		IF NOT GAZ_shiber_closed_state THEN
			IF GAZ_shiber_error THEN
				case_counter := ST_STOP_BURNER;
			END_IF;
		END_IF;

		IF shiber_closed_state AND GAZ_shiber_closed_state THEN
			add_time := clock - burner_start_time;
			impuls_ventilator_start(CLK := TRUE, Q => ventilator_start);
			case_counter := ST_START_FAN;
		END_IF;


	ST_START_FAN:
		// Ожидаем включение вентилятора
		IF NOT ventilator_state THEN
			IF time_wait(burner_start_time, (2 + add_time)) THEN
				burner_state.2 := TRUE;  // Не включился вентилятор
				case_counter := ST_STOP_BURNER;
			END_IF;
		ELSE
			add_time := clock - burner_start_time;
			impuls_PZK_1_start(CLK := TRUE, Q => PZK_1_on);
			case_counter := ST_WAIT_PZK1_OPEN;
		END_IF;


	ST_WAIT_PZK1_OPEN:
		// Ожидаем открытия ПЗК-1
		IF NOT PZK_1_open THEN
			IF time_wait(burner_start_time, (REAL_TO_DWORD(burner_control_settings.Value[IDX_PZK1_OPEN_WAIT]) + add_time)) THEN
				burner_state.4 := TRUE;  // Ошибка открытия ПЗК-1
				case_counter := ST_STOP_BURNER;
			END_IF;
		ELSE
			add_time := clock - burner_start_time;
			case_counter := ST_START_IGNITION;
		END_IF;


	ST_START_IGNITION:
		// Запускаем запальник, если он ещё не горит
		IF NOT ignition_flame THEN
			impuls_ignition_start(CLK := TRUE, Q => Ignition_start);
			case_counter := ST_WAIT_IGNITION_READY;
		ELSE
			case_counter := ST_OPEN_PZK2;
		END_IF;


	ST_WAIT_IGNITION_READY:
		// Ждём готовности запальника
		IF NOT ignition_ready THEN
			IF ignition_error OR time_wait(burner_start_time, (add_time + REAL_TO_DWORD(burner_control_settings.Value[IDX_IGNITION_WAIT]))) THEN
				case_counter := ST_STOP_BURNER;
			END_IF;
		ELSE
			add_time := clock - burner_start_time;
			case_counter := ST_OPEN_PZK2;
		END_IF;


	ST_OPEN_PZK2:
		// Открываем ПЗК-2 и сразу переходим к ожиданию пламени
		impuls_PZK_2_start(CLK := TRUE, Q => PZK_2_on);
		add_time := clock - burner_start_time;
		case_counter := ST_WAIT_FLAME;


	ST_WAIT_FLAME:
		// Ждём пламени горелки
		IF time_wait(burner_start_time, (add_time + REAL_TO_DWORD(burner_control_settings.Value[IDX_FLAME_WAIT]))) THEN
			IF NOT pilot_flame THEN
				burner_state.7 := TRUE;  // Долго нет пламени горелки
			END_IF;
			add_time := clock - burner_start_time;
			case_counter := ST_GAS_DAMPER_ACTION;
		END_IF;


	ST_GAS_DAMPER_ACTION:
		// Операции с заслонкой газа
		impuls_ignition_stop(CLK := TRUE, Q => Ignition_stop);

		IF REAL_TO_BOOL(burner_control_settings.Value[IDX_DAMPER_MODE]) THEN
			impuls_GAZ_shiber_auto(CLK := TRUE, Q => GAZ_shiber_auto);
		ELSE
			impuls_GAZ_shiber_open(CLK := TRUE, Q => GAZ_shiber_open_out);
		END_IF;

		case_counter := ST_WAIT_GAS_DELAY;


	ST_WAIT_DAMPERS_OPEN:
		// Ждём открытия шибера воздуха и заслонки газа
		IF NOT shiber_open_state THEN
			IF shiber_error THEN
				case_counter := ST_STOP_BURNER;
			END_IF;
		END_IF;

		IF NOT GAZ_shiber_open_state THEN
			IF GAZ_shiber_error THEN
				case_counter := ST_STOP_BURNER;
			END_IF;
		END_IF;

		IF shiber_open_state AND GAZ_shiber_open_state THEN
			case_counter := ST_BURNER_WORK;
		END_IF;


	ST_BURNER_WORK:
		// Горелка в работе
		impuls_GAZ_shiber_manual(CLK := TRUE, Q => GAZ_shiber_manual);
		burner_state.5 := TRUE;
		burner_work := TRUE;
		burner_state.0 := FALSE;
		case_counter := ST_IDLE;


	ST_WAIT_GAS_DELAY:
		// Ожидаем паузу между пуском заслонки газа и шибера воздуха
		IF time_wait(burner_start_time, (add_time + REAL_TO_DWORD(burner_control_settings.Value[IDX_AIR_DELAY]))) THEN
			add_time := clock - burner_start_time;
			case_counter := ST_AIR_SHIBER_ACTION;
		END_IF;


	ST_AIR_SHIBER_ACTION:
		// Операции с шибером воздуха
		IF REAL_TO_BOOL(burner_control_settings.Value[IDX_DAMPER_MODE]) THEN
			impuls_shiber_auto(CLK := TRUE, Q => shiber_auto);
		ELSE
			impuls_shiber_open(CLK := TRUE, Q => shiber_open_out);
		END_IF;

		case_counter := ST_WAIT_DAMPERS_OPEN;


	ST_STOP_BURNER:
		// Остановка горелки / выход из процедуры розжига
		IF burner_work THEN
			burner_state.3 := TRUE;     // Горелка остановлена
		ELSE
			burner_state.31 := TRUE;    // Процедура розжига остановлена
			IF kz_open THEN
				impuls_ignition_stop(CLK := TRUE, Q => Ignition_stop);
			END_IF;
		END_IF;

		burner_state.0 := FALSE;
		burner_work := FALSE;

		impuls_PZK_2_stop(CLK := TRUE, Q => PZK_2_off);
		impuls_PZK_1_stop(CLK := TRUE, Q => PZK_1_off);

		// Закрываем заслонку газа и переводим в ручной
		impuls_GAZ_shiber_manual(CLK := TRUE, Q => GAZ_shiber_manual);
		impuls_GAZ_shiber_closed(CLK := TRUE, Q => GAZ_shiber_closed_out);

		// Шибер воздуха в ручной
		impuls_shiber_manual(CLK := TRUE, Q => shiber_manual);

		// Положение ШВ при останове:
		// 0 = закрыть, 1 = оставить в текущем положении
		IF NOT boiler_alarm THEN
			IF REAL_TO_DWORD(burner_control_settings.Value[IDX_SHIBER_STOP_MODE]) = 0 THEN
				impuls_shiber_closed(CLK := TRUE, Q => shiber_closed_out);
			END_IF;
		END_IF;

		// Вентилятор горелки блоком розжига не останавливаем
		case_counter := ST_IDLE;

END_CASE;


// Стирание сообщений через 1 секунду
clear_ton[1](IN := burner_state.3, PT := T#1S);
clear_ton[2](IN := burner_state.4, PT := T#1S);
clear_ton[3](IN := burner_state.5, PT := T#1S);
clear_ton[4](IN := burner_state.7, PT := T#1S);
clear_ton[5](IN := burner_state.2, PT := T#1S);
clear_ton[6](IN := burner_state.31, PT := T#1S);

IF clear_ton[1].Q THEN burner_state.3 := FALSE; END_IF;
IF clear_ton[2].Q THEN burner_state.4 := FALSE; END_IF;
IF clear_ton[3].Q THEN burner_state.5 := FALSE; END_IF;
IF clear_ton[4].Q THEN burner_state.7 := FALSE; END_IF;
IF clear_ton[5].Q THEN burner_state.2 := FALSE; END_IF;
IF clear_ton[6].Q THEN burner_state.31 := FALSE; END_IF;