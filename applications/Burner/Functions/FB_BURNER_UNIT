FUNCTION_BLOCK FB_BURNER_UNIT
VAR_INPUT
	burner_id : WORD;
	enable    : BOOL;
END_VAR

VAR_OUTPUT
	ready     : BOOL;
	run       : BOOL;
	alarm     : BOOL;
	warning   : BOOL;
	state     : DWORD;
END_VAR

VAR
	burner_data    : ST_BURNER_DATA;
	ignition_data  : ST_BURNER_IGNITION_DATA;
	pressure_data  : ST_BURNER_PRESSURE_DATA;
	protect_data   : ST_BURNER_PROTECT_DATA;
	regulator_data : ST_BURNER_REGULATOR_DATA;
	valve_data     : ST_BURNER_VALVE_DATA;
	hmi_sync       : FB_BURNER_HMI_SYNC;
	pressure       : FB_BURNER_PRESSURE;
	ignition       : FB_BURNER_IGNITION;
	regulator      : FB_BURNER_REGULATOR;
	armature       : FB_BURNER_ARMATURE;
	protect        : FB_BURNER_PROTECT;
	pressure_in_progress : BOOL;
	ignition_in_progress : BOOL;
END_VAR

VAR CONSTANT
	BURNER_STATE_DISABLED         : DWORD := DWORD#0;
	BURNER_STATE_STOPPED          : DWORD := DWORD#1;
	BURNER_STATE_READY            : DWORD := DWORD#2;
	BURNER_STATE_PRESSURE_ACTIVE  : DWORD := DWORD#3;
	BURNER_STATE_IGNITION_ACTIVE  : DWORD := DWORD#4;
	BURNER_STATE_RUN              : DWORD := DWORD#5;
	BURNER_STATE_WARNING          : DWORD := DWORD#6;
	BURNER_STATE_ALARM            : DWORD := DWORD#7;
END_VAR

// === IMPLEMENTATION ===

(*
FB_BURNER_UNIT - будущий контейнер данных одной горелки.
Блок вызывается через BURNERS_MANAGER из MAIN.
Текущую рабочую логику одной горелки этот блок пока не заменяет полностью.
Вентиляция остается логикой уровня котла и в этот блок не входит.
Логика AutoBurner и автоматическая цепочка "вентиляция -> опрессовка -> розжиг" намеренно исключены.
Внутренние структуры сохраняют текущую локальную индексацию,
а HMI/OPC UA используют отдельные плоские карты GVL_BURNER_*.
*)

hmi_sync(
	burner_id := burner_id,
	enable := enable,
	burner_data := burner_data,
	pressure_data := pressure_data,
	ignition_data := ignition_data,
	protect_data := protect_data,
	regulator_data := regulator_data,
	valve_data := valve_data
);

IF enable THEN
	burner_data.burner_start := burner_data.start_cmd;
	burner_data.burner_stop := burner_data.stop_cmd;
	burner_data.boiler_run := valve_data.open_state[pzk_2] AND NOT burner_data.burner_stop AND NOT protect_data.main_alarm;
ELSE
	burner_data.burner_start := FALSE;
	burner_data.burner_stop := FALSE;
	burner_data.boiler_run := FALSE;
END_IF;

pressure(
	burner_id := burner_id,
	enable := enable,
	pressure_data := pressure_data,
	burner_data := burner_data,
	valve_data := valve_data
);

ignition(
	burner_id := burner_id,
	enable := enable,
	ignition_data := ignition_data,
	valve_data := valve_data
);

regulator(
	burner_id := burner_id,
	enable := enable,
	regulator_data := regulator_data,
	burner_data := burner_data,
	valve_data := valve_data,
	protect_data := protect_data
);

armature(
	burner_id := burner_id,
	enable := enable,
	valve_data := valve_data,
	burner_data := burner_data,
	ignition_data := ignition_data,
	pressure_data := pressure_data,
	regulator_data := regulator_data
);

protect(
	burner_id := burner_id,
	enable := enable,
	protect_data := protect_data,
	burner_data := burner_data,
	valve_data := valve_data,
	ignition_data := ignition_data,
	pressure_data := pressure_data
);

IF NOT enable THEN
	ready := FALSE;
	run := FALSE;
	alarm := FALSE;
	warning := FALSE;
	state := BURNER_STATE_DISABLED;
	burner_data.ready := FALSE;
	burner_data.alarm := FALSE;
	burner_data.warning := FALSE;
	burner_data.state := BURNER_STATE_DISABLED;
ELSE
	pressure_in_progress := (pressure_data.state AND DWORD#16#00000002) <> DWORD#0;
	ignition_in_progress := (ignition_data.state AND DWORD#16#00000001) <> DWORD#0;

	burner_data.burner_start := burner_data.start_cmd;
	burner_data.burner_stop := burner_data.stop_cmd;
	burner_data.alarm := protect_data.main_alarm OR pressure_data.alarm OR ignition_data.alarm OR regulator_data.alarm;
	burner_data.warning := protect_data.main_warning OR pressure_data.warning OR ignition_data.warning OR regulator_data.warning;
	burner_data.boiler_run := valve_data.open_state[pzk_2] AND NOT burner_data.burner_stop AND NOT burner_data.alarm;
	burner_data.ready := pressure_data.ready
		AND NOT burner_data.alarm
		AND NOT burner_data.boiler_run
		AND NOT burner_data.burner_start
		AND NOT pressure_in_progress
		AND NOT ignition_in_progress;

	IF burner_data.alarm THEN
		burner_data.state := BURNER_STATE_ALARM;
	ELSIF burner_data.boiler_run THEN
		burner_data.state := BURNER_STATE_RUN;
	ELSIF ignition_in_progress THEN
		burner_data.state := BURNER_STATE_IGNITION_ACTIVE;
	ELSIF pressure_in_progress THEN
		burner_data.state := BURNER_STATE_PRESSURE_ACTIVE;
	ELSIF burner_data.warning THEN
		burner_data.state := BURNER_STATE_WARNING;
	ELSIF burner_data.ready THEN
		burner_data.state := BURNER_STATE_READY;
	ELSE
		burner_data.state := BURNER_STATE_STOPPED;
	END_IF;

	ready := burner_data.ready;
	run := burner_data.boiler_run;
	alarm := burner_data.alarm;
	warning := burner_data.warning;
	state := burner_data.state;
END_IF;
