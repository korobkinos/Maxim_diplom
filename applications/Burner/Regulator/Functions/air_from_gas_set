FUNCTION_BLOCK air_from_gas_set
VAR_INPUT
    gas_sensor : REAL;                     // Давление газа
    settings : GAS_AIR_PROPORTION;         // Таблица точек (10 точек, индексы 1..10)
END_VAR
VAR_OUTPUT
    air_set_point : REAL;                  // Уставка для регулятора воздуха
    shiber_percent : REAL;                 // Процент открытия ШВ
END_VAR
VAR
    i : INT;
    step : INT;
    gas_min, gas_max, air_min, air_max, shiber_min, shiber_max : REAL;
    t : REAL;
END_VAR

// === IMPLEMENTATION ===

// 1. Поиск интервала (предполагается, что GAS_VALUE[i] возрастают)
step := 1;
FOR i := 1 TO 9 DO
    IF gas_sensor >= settings.GAS_VALUE[i] AND gas_sensor < settings.GAS_VALUE[i+1] THEN
        step := i;
        EXIT;
    END_IF
END_FOR

// 2. Коррекция для крайних значений
IF gas_sensor <= settings.GAS_VALUE[1] THEN
    step := 1;
ELSIF gas_sensor >= settings.GAS_VALUE[10] THEN
    step := 9;
END_IF

// 3. Точки интервала
gas_min   := settings.GAS_VALUE[step];
gas_max   := settings.GAS_VALUE[step+1];
air_min   := settings.AIR_VALUE[step];
air_max   := settings.AIR_VALUE[step+1];
shiber_min := settings.SHIBER_VALUE[step];
shiber_max := settings.SHIBER_VALUE[step+1];

// 4. Линейная интерполяция (с защитой от деления на ноль)
IF gas_max > gas_min THEN
    t := (gas_sensor - gas_min) / (gas_max - gas_min);
    t := MAX(0.0, MIN(1.0, t));   // ограничиваем [0..1]
ELSE
    t := 0.0;
END_IF

air_set_point  := air_min + t * (air_max - air_min);
shiber_percent := shiber_min + t * (shiber_max - shiber_min);