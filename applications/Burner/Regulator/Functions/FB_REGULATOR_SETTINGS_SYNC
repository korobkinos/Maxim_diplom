FUNCTION_BLOCK FB_REGULATOR_SETTINGS_SYNC
VAR
	burner_id : WORD;
	reg_local_idx : WORD;
	reg_flat_idx : WORD;
	item_idx : WORD;
	sensor_idx : WORD;
	flat_idx : WORD;
	load_requested : BOOL;
	save_requested : BOOL;
	init_done : BOOL;
	binding_cfg : ST_REGULATOR_BINDING;
END_VAR

VAR CONSTANT
	gas_air_point_count : WORD := 10;
	binding_enabled_item_idx : WORD := 1;
	binding_pid_item_idx : WORD := 2;
	binding_valve_item_idx : WORD := 3;
	binding_pv_item_idx : WORD := 4;
	binding_proc_item_idx : WORD := 5;
	pv_sensor_count : WORD := 3;
END_VAR

// === IMPLEMENTATION ===

IF NOT init_done THEN
	FOR burner_id := 1 TO burner_quantity DO
		FOR reg_local_idx := 0 TO burner_regulator_quantity - 1 DO
			reg_flat_idx := (burner_id - 1) * burner_regulator_quantity + reg_local_idx + 1;
			binding_cfg := SETTINGS.regulator_settings[burner_id].binding[reg_local_idx];

			FOR item_idx := 1 TO pid_settings_quantity DO
				flat_idx := (reg_flat_idx - 1) * pid_settings_quantity + item_idx;
				IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * pid_settings_quantity) THEN
					GVL_BURNER_REGULATOR_HMI.hmi_regulator_pid_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].pid[reg_local_idx].VALUE[item_idx];
				END_IF;
			END_FOR;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_enabled_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.enabled;
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_pid_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.pid_idx;
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_valve_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.valve_idx;
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_pv_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.pv_ai_idx[1];
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_proc_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.position_ai_idx;
			END_IF;

			FOR sensor_idx := 1 TO pv_sensor_count DO
				flat_idx := ((burner_id - 1) * burner_regulator_quantity + reg_local_idx) * pv_sensor_count + sensor_idx;
				IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * pv_sensor_count) THEN
					GVL_BURNER_REGULATOR_HMI.hmi_regulator_pv_ai_idx_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].binding[reg_local_idx].pv_ai_idx[sensor_idx];
				END_IF;
			END_FOR;

			flat_idx := (burner_id - 1) * burner_regulator_quantity + reg_local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_position_ai_idx[flat_idx] := SETTINGS.regulator_settings[burner_id].binding[reg_local_idx].position_ai_idx;
			END_IF;
		END_FOR;

		FOR item_idx := 1 TO gas_air_point_count DO
			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].gas_air_map.GAS_VALUE[item_idx];
			END_IF;

			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx + gas_air_point_count;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].gas_air_map.AIR_VALUE[item_idx];
			END_IF;

			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx + gas_air_point_count + gas_air_point_count;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].gas_air_map.SHIBER_VALUE[item_idx];
			END_IF;
		END_FOR;
	END_FOR;

	init_done := TRUE;
END_IF;

load_requested := GVL_BURNER_REGULATOR_HMI.hmi_load_settings;
save_requested := GVL_BURNER_REGULATOR_HMI.hmi_save_settings;

IF load_requested THEN
	FOR burner_id := 1 TO burner_quantity DO
		FOR reg_local_idx := 0 TO burner_regulator_quantity - 1 DO
			reg_flat_idx := (burner_id - 1) * burner_regulator_quantity + reg_local_idx + 1;
			binding_cfg := SETTINGS.regulator_settings[burner_id].binding[reg_local_idx];

			FOR item_idx := 1 TO pid_settings_quantity DO
				flat_idx := (reg_flat_idx - 1) * pid_settings_quantity + item_idx;
				IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * pid_settings_quantity) THEN
					GVL_BURNER_REGULATOR_HMI.hmi_regulator_pid_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].pid[reg_local_idx].VALUE[item_idx];
				END_IF;
			END_FOR;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_enabled_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.enabled;
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_pid_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.pid_idx;
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_valve_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.valve_idx;
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_pv_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.pv_ai_idx[1];
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_proc_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx] := binding_cfg.position_ai_idx;
			END_IF;

			FOR sensor_idx := 1 TO pv_sensor_count DO
				flat_idx := ((burner_id - 1) * burner_regulator_quantity + reg_local_idx) * pv_sensor_count + sensor_idx;
				IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * pv_sensor_count) THEN
					GVL_BURNER_REGULATOR_HMI.hmi_regulator_pv_ai_idx_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].binding[reg_local_idx].pv_ai_idx[sensor_idx];
				END_IF;
			END_FOR;

			flat_idx := (burner_id - 1) * burner_regulator_quantity + reg_local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_position_ai_idx[flat_idx] := SETTINGS.regulator_settings[burner_id].binding[reg_local_idx].position_ai_idx;
			END_IF;
		END_FOR;

		FOR item_idx := 1 TO gas_air_point_count DO
			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].gas_air_map.GAS_VALUE[item_idx];
			END_IF;

			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx + gas_air_point_count;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].gas_air_map.AIR_VALUE[item_idx];
			END_IF;

			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx + gas_air_point_count + gas_air_point_count;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx] := SETTINGS.regulator_settings[burner_id].gas_air_map.SHIBER_VALUE[item_idx];
			END_IF;
		END_FOR;
	END_FOR;

	GVL_BURNER_REGULATOR_HMI.hmi_load_settings := FALSE;
ELSIF save_requested THEN
	FOR burner_id := 1 TO burner_quantity DO
		FOR reg_local_idx := 0 TO burner_regulator_quantity - 1 DO
			reg_flat_idx := (burner_id - 1) * burner_regulator_quantity + reg_local_idx + 1;
			binding_cfg := SETTINGS.regulator_settings[burner_id].binding[reg_local_idx];

			FOR item_idx := 1 TO pid_settings_quantity DO
				flat_idx := (reg_flat_idx - 1) * pid_settings_quantity + item_idx;
				IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * pid_settings_quantity) THEN
					SETTINGS.regulator_settings[burner_id].pid[reg_local_idx].VALUE[item_idx] := GVL_BURNER_REGULATOR_HMI.hmi_regulator_pid_flat[flat_idx];
				END_IF;
			END_FOR;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_enabled_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				binding_cfg.enabled := GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx];
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_pid_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				binding_cfg.pid_idx := GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx];
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_valve_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				binding_cfg.valve_idx := GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx];
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_pv_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				binding_cfg.pv_ai_idx[1] := GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx];
			END_IF;

			flat_idx := (reg_flat_idx - 1) * burner_reg_binding_item_quantity + binding_proc_item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * burner_reg_binding_item_quantity) THEN
				binding_cfg.position_ai_idx := GVL_BURNER_REGULATOR_HMI.hmi_regulator_binding_flat[flat_idx];
			END_IF;

			FOR sensor_idx := 1 TO pv_sensor_count DO
				flat_idx := ((burner_id - 1) * burner_regulator_quantity + reg_local_idx) * pv_sensor_count + sensor_idx;
				IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity * pv_sensor_count) THEN
					binding_cfg.pv_ai_idx[sensor_idx] := GVL_BURNER_REGULATOR_HMI.hmi_regulator_pv_ai_idx_flat[flat_idx];
				END_IF;
			END_FOR;

			flat_idx := (burner_id - 1) * burner_regulator_quantity + reg_local_idx + 1;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * burner_regulator_quantity) THEN
				binding_cfg.position_ai_idx := GVL_BURNER_REGULATOR_HMI.hmi_regulator_position_ai_idx[flat_idx];
			END_IF;

			SETTINGS.regulator_settings[burner_id].binding[reg_local_idx] := binding_cfg;
		END_FOR;

		FOR item_idx := 1 TO gas_air_point_count DO
			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				SETTINGS.regulator_settings[burner_id].gas_air_map.GAS_VALUE[item_idx] := GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx];
			END_IF;

			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx + gas_air_point_count;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				SETTINGS.regulator_settings[burner_id].gas_air_map.AIR_VALUE[item_idx] := GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx];
			END_IF;

			flat_idx := (burner_id - 1) * gas_air_map_quantity + item_idx + gas_air_point_count + gas_air_point_count;
			IF (flat_idx >= 1) AND (flat_idx <= burner_quantity * gas_air_map_quantity) THEN
				SETTINGS.regulator_settings[burner_id].gas_air_map.SHIBER_VALUE[item_idx] := GVL_BURNER_REGULATOR_HMI.hmi_regulator_gas_air_flat[flat_idx];
			END_IF;
		END_FOR;
	END_FOR;

	GVL_BURNER_REGULATOR_HMI.hmi_save_settings := FALSE;
END_IF;
