FUNCTION_BLOCK shiber_singl  
VAR_INPUT
	open_state:BOOL;//Активен концевик открытого состояния
	closed_state:BOOL;//Активен концевик закрытого состояния
	special_state:BOOL;//Концевик специальной позиции
	up:BOOL;//больше (удерживать)
	down:BOOL;//Меньше (удерживать)
	open:BOOL;//Открыть
	closed:BOOL;//закрыть
	stop:BOOL;//Остановить
	special_set:BOOL;//Установить на специальную позицию
	wait_time:REAL:= 70;//Время ожидания ИМ
	pull_time:REAL;//время дожима ИМ
END_VAR
VAR_OUTPUT
	open_out:BOOL;//Команда на открытие шибера
	closed_out:BOOL;//Команда на закрытие шибера
	stop_out:BOOL;
	error:BOOL;//Ошибка
	open_state_active:BOOL;//Состояние открытого после дожима
	closed_state_active:BOOL;//Состояние закрытого после дожима
	
	state:DWORD;//Состояние
							//25-ИМ не открылся
							//26-ИМ не закрылся
							//27-ИМ не ущёл с закрытого
							
END_VAR

VAR
	RTC_RESULT:UDINT;
	clock:DWORD;
	start_time:DWORD;
	open_trig:BOOL;
	closed_trig:BOOL;
	open_active_trig:r_trig;
	closed_active_trig:r_trig;
	special_set_trig:r_trig;
	special_trig:BOOL;
	error_TON:TON;
	open_active:BOOL;
	closed_active:BOOL;
	block:BOOL;//Блокировка на время хода
	up_auto:BOOL;
	down_auto:BOOL;
	case_counter:WORD;//Счётчик кейсов
	clear:BOOL;//Очистить сообщения
	
	open_state_ton:ton;
	closed_state_ton:ton;
	change_direction_tof:tof;
	change_direction_ftrig:f_trig;
	open_memory:BOOL;
	closed_memory:BOOL;
	
END_VAR

// === IMPLEMENTATION ===

clock:=SysTimeRTCGet(pResult:=RTC_RESULT);(*Часы реального времени*)
error:=FALSE;
block:=FALSE;

//
IF open AND closed_out THEN
	open_memory:= TRUE;
END_IF
IF closed AND open_out THEN
	closed_memory:= TRUE;
END_IF

//Смена направления
change_direction_tof(	IN:= (open AND closed_out) OR (closed AND open_out),
						PT:= T#1S);
//
stop:= stop OR change_direction_tof.Q;
//
change_direction_ftrig(CLK:= change_direction_tof.Q);
//
IF (open_memory OR closed_memory) AND change_direction_ftrig.Q THEN
	open:= open_memory;
	closed:= closed_memory;
	open_memory:= FALSE;
	closed_memory:= FALSE;
END_IF

//Блокировка при управлении выходами
IF open_out OR closed_out OR change_direction_tof.Q THEN
	block:=TRUE;
END_IF

//Определение команды открытия
open_active_trig(CLK:=open AND NOT block,Q=>open_active);
IF open_active THEN
	up_auto:=TRUE;
	down_auto:=FALSE;
	case_counter:=1;
END_IF

//Определение команды закрытия
closed_active_trig(CLK:=closed AND NOT block,Q=>closed_active);
IF closed_active THEN
	down_auto:=TRUE;
	up_auto:=FALSE;
	case_counter:=2;
END_IF

//Определение команды открытия на вентиляцию
special_set_trig(CLK:=special_set(* AND closed_state*));
IF special_set_trig.Q THEN
	up_auto:=TRUE;
	special_trig:= TRUE;
END_IF

//Определение открытия на вентиляцию (или полного)
IF special_trig THEN
	IF special_state OR open_state THEN
		up_auto:=FALSE;
		special_trig:= FALSE;
	END_IF
END_IF

 //Определение дожима
open_state_ton(IN:=open_state,PT:=REAL_TO_TIME(1000 * pull_time),Q=>open_state_active);
closed_state_ton(IN:=closed_state,PT:=REAL_TO_TIME(1000 * pull_time),Q=>closed_state_active);

//Селектор команд управления
IF up OR down THEN
	up_auto:=FALSE;//Отмена автомата при нажатии на кнопку????
	down_auto:=FALSE;//Отмена автомата при нажатии на кнопку????
END_IF

//Управление БОЛЬШЕ
IF (up OR up_auto) AND NOT (down OR down_auto) AND NOT open_state_active THEN
	IF up THEN
		case_counter:= 0;
	END_IF
	open_out:=TRUE;
	IF open_trig THEN
		start_time:=clock;
		open_trig:=FALSE;
	END_IF
ELSE
	open_out:=FALSE;
	open_trig:=TRUE;
	up_auto:=FALSE;
END_IF
//Управление МЕНЬШЕ
IF (down OR down_auto) AND NOT (up OR up_auto) AND NOT closed_state_active THEN
	IF down THEN
		case_counter:= 0;
	END_IF
	closed_out:=TRUE;
	IF closed_trig THEN
		start_time:=clock;
		closed_trig:=FALSE;
	END_IF
ELSE
	closed_out:=FALSE;
	closed_trig:=TRUE;
	down_auto:=FALSE;
END_IF

//Определение стоп
IF stop THEN
	up_auto:=FALSE;
	down_auto:=FALSE;
	case_counter:=0;		
END_IF

CASE case_counter OF
	1://Ожидаем открытия или истечения время ожидания
	IF NOT open_state THEN
		IF time_wait(start_time,REAL_TO_DWORD(wait_time)) THEN
			IF closed_state THEN//Определение не ухода с закрытого
				state.27:=TRUE;//29-ШВ не ущёл с закрытого
			END_IF
			state.25:=TRUE;//24-Шибер не открылся
			up_auto:=FALSE;
			case_counter:=0;
		END_IF			
	ELSE
		case_counter:=0;
	END_IF
	2://Ожидаем закрытия или истечения время ожидания
	IF NOT closed_state THEN
		IF time_wait(start_time,REAL_TO_DWORD(wait_time)) THEN
			state.26:=TRUE;//25-Шибер не закрылся
			down_auto:=FALSE;
			case_counter:=0;
		END_IF			
	ELSE
		case_counter:=0;
	END_IF
END_CASE

//Определение одновременного включения
IF up AND down THEN
	error:=TRUE;
END_IF
IF open AND closed THEN
	error:=TRUE;
END_IF

//Определение ошибки шибера
IF	state.25 OR//24-Шибер не открылся
	state.26 OR//25-Шибер не закрылся
	state.27//29-ШВ не ущёл с закрытого
THEN
	error:=TRUE;
END_IF

//Блокировка выходов при ERROR
IF error THEN
	open_out:=FALSE;
	closed_out:=FALSE;
END_IF

//Очистка сообщений
error_TON(in:= error, pt:= T#5S, q=> clear);
IF clear THEN
	state:=0;
END_IF