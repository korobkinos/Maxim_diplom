FUNCTION_BLOCK FB_BURNER_ARMATURE
VAR_INPUT
	burner_id : WORD;
	enable    : BOOL;
END_VAR

VAR_IN_OUT
	valve_data     : ST_BURNER_VALVE_DATA;
	burner_data    : ST_BURNER_DATA;
	ignition_data  : ST_BURNER_IGNITION_DATA;
	pressure_data  : ST_BURNER_PRESSURE_DATA;
	regulator_data : ST_BURNER_REGULATOR_DATA;
END_VAR

VAR
	valves : ARRAY[0..burner_valve_quantity - 1] OF valve_universal_singl;

	up_cmd       : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	down_cmd     : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	open_cmd     : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	close_cmd    : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	block_cmd    : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	reg_up_cmd   : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	reg_down_cmd : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	reg_auto_cmd : ARRAY[0..burner_valve_quantity - 1] OF BOOL;
	reg_man_cmd  : ARRAY[0..burner_valve_quantity - 1] OF BOOL;

	cmd_up         : BOOL;
	cmd_down       : BOOL;
	cmd_open       : BOOL;
	cmd_closed     : BOOL;
	cmd_stop       : BOOL;
	cmd_block      : BOOL;
	cmd_set_auto   : BOOL;
	cmd_set_manual : BOOL;
	cmd_set_special: BOOL;
	cmd_imitation  : BOOL;
	effective_armature_simulation : BOOL;
	burner_id_valid : BOOL;
	local_idx_valid : BOOL;
	arm_idx : WORD;
	wait_time_cfg : REAL;
	pull_time_cfg : REAL;
	off_time_cfg : REAL;
	one_state_cfg : BOOL;
	block_mode_cfg : BOOL;

	i        : WORD;
	pid_idx  : WORD;
	valve_idx: WORD;
	binding_global_idx : WORD;
	binding_cfg : ST_REGULATOR_BINDING;
END_VAR

// === IMPLEMENTATION ===

(*
FB_BURNER_ARMATURE - будущая горелочная замена старого одногорелочного ARMATURE.
Старый ARMATURE остается без изменений.
Блок использует только внутренние данные будущего FB_BURNER_UNIT.
Вентиляция и AutoBurner в этот блок не входят.
BURNERS_MANAGER вызывается из MAIN.
Команды на vent_burner здесь оставлены только как ручная ветка управления арматурой.
*)

FOR i := 0 TO burner_valve_quantity - 1 DO
	open_cmd[i] := valve_data.open[i];
	close_cmd[i] := valve_data.closed[i];
	up_cmd[i] := valve_data.up[i];
	down_cmd[i] := valve_data.down[i];
	block_cmd[i] := valve_data.block[i];
	reg_up_cmd[i] := FALSE;
	reg_down_cmd[i] := FALSE;
	reg_auto_cmd[i] := FALSE;
	reg_man_cmd[i] := FALSE;
END_FOR;

burner_id_valid := (burner_id >= 1) AND (burner_id <= burner_quantity);

IF enable THEN
	up_cmd[gas_shiber] := up_cmd[gas_shiber] OR regulator_data.min_power_impulse_up;

	open_cmd[spark] := open_cmd[spark] OR ignition_data.spark_SET;
	close_cmd[spark] := close_cmd[spark] OR ignition_data.spark_RESET;

	open_cmd[pzk_1] := open_cmd[pzk_1] OR burner_data.PZK_1_SET OR pressure_data.PZK_1_SET OR ignition_data.PZK_1_SET;
	close_cmd[pzk_1] := close_cmd[pzk_1] OR burner_data.PZK_1_RESET OR pressure_data.PZK_1_RESET OR ignition_data.PZK_1_RESET;

	open_cmd[pzk_2] := open_cmd[pzk_2] OR burner_data.PZK_2_SET;
	close_cmd[pzk_2] := close_cmd[pzk_2] OR burner_data.PZK_2_RESET;

	open_cmd[air_shiber] := open_cmd[air_shiber] OR burner_data.shiber_open;
	close_cmd[air_shiber] := close_cmd[air_shiber] OR burner_data.shiber_closed;

	open_cmd[gas_shiber] := open_cmd[gas_shiber] OR burner_data.GAZ_shiber_open;
	close_cmd[gas_shiber] := close_cmd[gas_shiber] OR burner_data.GAZ_shiber_closed;

	open_cmd[kz] := open_cmd[kz] OR ignition_data.KZ_SET;
	close_cmd[kz] := close_cmd[kz] OR ignition_data.KZ_RESET;

	open_cmd[vent_burner] := open_cmd[vent_burner] OR burner_data.ventilator_burner_on;
	close_cmd[vent_burner] := close_cmd[vent_burner] OR burner_data.ventilator_burner_off;

	open_cmd[kb] := open_cmd[kb] OR pressure_data.KB_SET;
	close_cmd[kb] := close_cmd[kb] OR pressure_data.KB_RESET;

	open_cmd[ko] := open_cmd[ko] OR pressure_data.KO_SET;
	close_cmd[ko] := close_cmd[ko] OR pressure_data.KO_RESET;
END_IF;

FOR i := 0 TO PID_quantity DO
	binding_global_idx := 0;
	IF burner_id_valid THEN
		binding_global_idx := GetBurnerRegulatorIndex(burner_id := burner_id, local_idx := i);
	END_IF;
	IF burner_id_valid AND (binding_global_idx >= 1) AND (binding_global_idx <= burner_quantity * burner_regulator_quantity) THEN
		binding_cfg := SETTINGS.regulator_binding_map[binding_global_idx];
		IF binding_cfg.enabled = SETTINGS.reg_binding_on THEN
			pid_idx := binding_cfg.pid_idx;
			valve_idx := binding_cfg.valve_idx;
			IF (pid_idx >= 1) AND (pid_idx <= PID_quantity) AND (valve_idx >= 1) AND (valve_idx < burner_valve_quantity) THEN
				reg_up_cmd[valve_idx] := reg_up_cmd[valve_idx] OR regulator_data.reg_valve[pid_idx].up_out;
				reg_down_cmd[valve_idx] := reg_down_cmd[valve_idx] OR regulator_data.reg_valve[pid_idx].down_out;
				reg_auto_cmd[valve_idx] := reg_auto_cmd[valve_idx] OR regulator_data.reg_valve[pid_idx].auto_set;
				reg_man_cmd[valve_idx] := reg_man_cmd[valve_idx] OR regulator_data.reg_valve[pid_idx].man_set;
			END_IF;
		END_IF;
	END_IF;
END_FOR;

FOR i := 0 TO burner_valve_quantity - 1 DO
	local_idx_valid := i < burner_valve_quantity;
	arm_idx := 0;
	effective_armature_simulation := FALSE;
	wait_time_cfg := 0.0;
	pull_time_cfg := 0.0;
	off_time_cfg := 0.0;
	one_state_cfg := FALSE;
	block_mode_cfg := FALSE;
	IF burner_id_valid AND local_idx_valid THEN
		arm_idx := GetBurnerArmatureIndex(burner_id := burner_id, local_idx := i);
		IF (arm_idx >= 1) AND (arm_idx <= burner_quantity * burner_valve_quantity) THEN
			effective_armature_simulation := SETTINGS.armature_settings[arm_idx].simulation;
			wait_time_cfg := SETTINGS.armature_settings[arm_idx].wait_time;
			pull_time_cfg := SETTINGS.armature_settings[arm_idx].pull_time;
			off_time_cfg := SETTINGS.armature_settings[arm_idx].off_time;
			one_state_cfg := SETTINGS.armature_settings[arm_idx].one_state;
			block_mode_cfg := SETTINGS.armature_settings[arm_idx].block_mode;
		END_IF;
	END_IF;
	IF enable THEN
		cmd_up := up_cmd[i] OR reg_up_cmd[i];
		cmd_down := down_cmd[i] OR reg_down_cmd[i];
		cmd_open := open_cmd[i];
		cmd_closed := close_cmd[i];
		cmd_stop := valve_data.stop[i];
		cmd_block := block_cmd[i];
		cmd_set_auto := valve_data.set_auto[i] OR reg_auto_cmd[i];
		cmd_set_manual := valve_data.open[i] OR valve_data.closed[i] OR valve_data.set_manual[i] OR reg_man_cmd[i];
		cmd_set_special := valve_data.set_special[i];
		cmd_imitation := valve_data.imitation_mode[i] OR effective_armature_simulation;
	ELSE
		cmd_up := FALSE;
		cmd_down := FALSE;
		cmd_open := FALSE;
		cmd_closed := FALSE;
		cmd_stop := FALSE;
		cmd_block := TRUE;
		cmd_set_auto := FALSE;
		cmd_set_manual := FALSE;
		cmd_set_special := FALSE;
		cmd_imitation := FALSE;
	END_IF;

	valves[i](
		up := cmd_up,
		down := cmd_down,
		open := cmd_open,
		closed := cmd_closed,
		stop := cmd_stop,
		set_special := cmd_set_special,
		set_auto := cmd_set_auto,
		set_manual := cmd_set_manual,
		block := cmd_block,
		open_state_di := valve_data.open_state_di[i],
		closed_state_di := valve_data.closed_state_di[i],
		special_state_di := valve_data.special_state_di[i],
		wait_time := wait_time_cfg,
		pull_time := pull_time_cfg,
		off_time := off_time_cfg,
		one_state := one_state_cfg,
		imitation_mode := cmd_imitation,
		block_mode := block_mode_cfg,
		load_state := FALSE,
		control_out => valve_data.control_out[i],
		auto_mode => valve_data.auto_mode[i],
		open_state => valve_data.open_state[i],
		closed_state => valve_data.closed_state[i],
		up_out => valve_data.up_out[i],
		down_out => valve_data.down_out[i],
		move_out => valve_data.move_out[i],
		error => valve_data.error_out[i],
		state => valve_data.state[i],
		percent_imitation => valve_data.percent[i]
	);
END_FOR;

FOR i := 0 TO PID_quantity DO
	regulator_data.reg_valve[i].open_state := FALSE;
	regulator_data.reg_valve[i].closed_state := FALSE;
END_FOR;

FOR i := 0 TO PID_quantity DO
	binding_global_idx := 0;
	IF burner_id_valid THEN
		binding_global_idx := GetBurnerRegulatorIndex(burner_id := burner_id, local_idx := i);
	END_IF;
	IF burner_id_valid AND (binding_global_idx >= 1) AND (binding_global_idx <= burner_quantity * burner_regulator_quantity) THEN
		binding_cfg := SETTINGS.regulator_binding_map[binding_global_idx];
		IF binding_cfg.enabled = SETTINGS.reg_binding_on THEN
			pid_idx := binding_cfg.pid_idx;
			valve_idx := binding_cfg.valve_idx;
			IF (pid_idx >= 1) AND (pid_idx <= PID_quantity) AND (valve_idx >= 1) AND (valve_idx < burner_valve_quantity) THEN
				regulator_data.reg_valve[pid_idx].open_state := valve_data.open_state[valve_idx];
				regulator_data.reg_valve[pid_idx].closed_state := valve_data.closed_state[valve_idx];
			END_IF;
		END_IF;
	END_IF;
END_FOR;
