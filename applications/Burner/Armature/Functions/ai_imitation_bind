//привязка % арматуры к аналогам с суммированием и ограничением 0..100
FUNCTION ai_imitation_bind : BOOL
VAR_INPUT
	enable: BOOL;
	//1..4 - № AI в массиве ai_in, 0 = нет привязки
	map_bind: ARRAY[1..total_burner_armature_quantity] OF ARRAY[1..4] OF WORD;
	percent_imitation: ARRAY[1..total_burner_armature_quantity] OF REAL;
END_VAR

VAR_IN_OUT
	ai_in: ARRAY[0..in_out_quantity] OF REAL;
END_VAR

VAR
	arm_idx: WORD;
	j: WORD;
	ai_idx: WORD;
	sum_ai: ARRAY[0..in_out_quantity] OF REAL;
	has_binding: ARRAY[0..in_out_quantity] OF BOOL;
END_VAR

// === IMPLEMENTATION ===

ai_imitation_bind := FALSE;
IF NOT enable THEN
	RETURN;
END_IF;

FOR ai_idx := 0 TO in_out_quantity DO
	sum_ai[ai_idx] := 0.0;
	has_binding[ai_idx] := FALSE;
END_FOR;

//собираем сумму от всех арматур
FOR arm_idx := 1 TO total_burner_armature_quantity DO
	FOR j := 1 TO 4 DO
		ai_idx := map_bind[arm_idx][j];

		//0 = нет привязки
		IF (ai_idx >= 1) AND (ai_idx <= in_out_quantity) THEN
			sum_ai[ai_idx] := sum_ai[ai_idx] + percent_imitation[arm_idx];
			has_binding[ai_idx] := TRUE;
		END_IF;
	END_FOR;
END_FOR;


//переносим результат в выходной массив с ограничением 0..100
FOR ai_idx := 1 TO in_out_quantity DO
	IF has_binding[ai_idx] THEN
		IF sum_ai[ai_idx] > 100.0 THEN
			ai_in[ai_idx] := 100.0;
		ELSIF sum_ai[ai_idx] < 0.0 THEN
			ai_in[ai_idx] := 0.0;
		ELSE
			ai_in[ai_idx] := sum_ai[ai_idx];
		END_IF;
	END_IF;
END_FOR;


ai_imitation_bind := TRUE;
