//привязка % арматуры к аналогам с суммированием и ограничением 0..100
FUNCTION ai_imitation_bind : BOOL
VAR_INPUT
	enable: ARRAY[0..burner_valve_quantity - 1] OF BOOL; //включить имитацию аналогов
	//0..4 - № AI в массиве ai_in, 0 = нет привязки
	map_bind: ARRAY[0..burner_valve_quantity - 1] OF ARRAY[0..4] OF WORD;
END_VAR

VAR_IN_OUT
	ai_in: ARRAY[0..in_out_quantity] OF REAL;
	percent_imitation: ARRAY[0..burner_valve_quantity - 1] OF REAL;
END_VAR

VAR
	i: WORD;
	j: WORD;
	ai_idx: WORD;
	sum_ai: ARRAY[0..in_out_quantity] OF REAL;
END_VAR

// === IMPLEMENTATION ===

//обнуляем внутренний массив сумм
FOR i := 0 TO in_out_quantity DO
	sum_ai[i] := 0.0;
END_FOR


//собираем сумму от всех арматур
FOR i := 0 TO burner_valve_quantity - 1 DO
	IF enable[i] THEN
		FOR j := 0 TO 4 DO
			ai_idx := map_bind[i][j];

			//0 = нет привязки
			IF (ai_idx <> 0) AND (ai_idx <= in_out_quantity) THEN
				sum_ai[ai_idx] := sum_ai[ai_idx] + percent_imitation[i];
			END_IF
		END_FOR
	END_IF
END_FOR


//переносим результат в выходной массив с ограничением 0..100
FOR i := 0 TO in_out_quantity DO
	IF sum_ai[i] > 100.0 THEN
		ai_in[i] := 100.0;
	ELSIF sum_ai[i] < 0.0 THEN
		ai_in[i] := 0.0;
	ELSE
		ai_in[i] := sum_ai[i];
	END_IF
END_FOR


ai_imitation_bind := TRUE;