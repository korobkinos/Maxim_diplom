TYPE PRESSURE_STATE_STRUCT :
STRUCT
	success             : BOOL; // bit0  - Опрессовано
	in_progress         : BOOL; // bit1  - Идёт опрессовка
	skipped             : BOOL; // bit2  - Опрессовка пропущена оператором
	reserved_3          : BOOL; // bit3  - резерв
	kb_not_closed       : BOOL; // bit4  - КБ не закрыт
	pzk1_leak           : BOOL; // bit5  - ПЗК-1 не плотен
	reserved_6          : BOOL; // bit6  - резерв
	skip_forbidden      : BOOL; // bit7  - Запрещено пропускать опрессовку
	timeout_cancel      : BOOL; // bit8  - Опрессовка отменена по таймеру
	aborted             : BOOL; // bit9  - Опрессовка отменена оператором
	msg_success         : BOOL; // bit10 - Сообщение "Опрессовано"
	msg_fail            : BOOL; // bit11 - Сообщение "Не опрессовано"
	overpressure        : BOOL; // bit12 - Давление велико, проверьте шайбу
	leak                : BOOL; // bit13 - Утечка ПЗК-2, КБ или КЗ
	full_success        : BOOL; // bit14 - Полная опрессовка выполнена (импульс)
	fast_success        : BOOL; // bit15 - Быстрая опрессовка выполнена (импульс)
	reserved_16         : BOOL; // bit16 - резерв
	abort_forbidden     : BOOL; // bit17 - Запрещено отменять опрессовку
END_STRUCT
END_TYPE