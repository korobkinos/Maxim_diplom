TYPE pressure_settings :
STRUCT
	VALUE : ARRAY[1..9] OF REAL := [5,80,3,7,30,10,24,1,0];
	// 1 - P_min, минимальное давление опрессовки
	// 2 - P_max, максимальное давление опрессовки
	// 3 - t_wait_1, выдержка перед подачей давления, сек
	// 4 - t_wait_2, время достижения P_min без достижения P_max, сек
	// 5 - t_wait_3, время достижения P_max / удержания давления, сек
	// 6 - t_fast, время быстрой опрессовки, сек
	// 7 - t_termination, время актуальности опрессовки, часы
	// 8 - наличие датчика КБ: 1 = есть, 0 = нет
	// 9 - режим опрессовки: 0 = через КО, 1 = через ПЗК-1
END_STRUCT
END_TYPE