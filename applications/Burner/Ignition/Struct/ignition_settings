TYPE ignition_settings :
STRUCT
	VALUE : ARRAY[1..5] OF REAL := [0,1,6,6,3];
	// 1 - Режим розжига:
	//     0 = ИСКРА/ГАЗ
	//     1 = ГАЗ/ИСКРА
	// 2 - Повторный розжиг:
	//     0 = без повтора
	//     1 = один повтор
	// 3 - t_ignition, продолжительность искры, сек
	// 4 - t_1, задержка между подачей газа и включением искры
	//     используется только в режиме ГАЗ/ИСКРА, сек
	// 5 - t_2, задержка между выключением искры и началом контроля пламени, сек
END_STRUCT
END_TYPE