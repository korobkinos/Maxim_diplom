FUNCTION_BLOCK ignition_singl
VAR_INPUT
	start: BOOL;                        // Команда на старт запальника
	start_block: BOOL;                  // Запрет старта запальника
	stop: BOOL;                         // Команда на стоп запальника
	ignition_flame: BOOL;               // Датчик пламени запальника
	PZK_1_state: BOOL;                  // Концевик открытого ПЗК-1

	ignition_settings: ignition_settings;
	// Value[1] = режим розжига: 0-ИСКРА/ГАЗ, 1-ГАЗ/ИСКРА
	// Value[2] = повторный розжиг: 0-нет, 1-есть
	// Value[3] = t_ignition, продолжительность искры
	// Value[4] = t_1, задержка между газом и искрой для режима ГАЗ/ИСКРА
	// Value[5] = t_2, задержка между выключением искры и началом контроля пламени
END_VAR

VAR_OUTPUT
	spark_on: BOOL;                     // Команда на пуск искроразрядника
	spark_off: BOOL;                    // Команда на стоп искроразрядника
	KZ_on: BOOL;                        // Команда на открытие клапана запальника
	KZ_off: BOOL;                       // Команда на закрытие клапана запальника
	PZK_1_on: BOOL;                     // Команда на открытие ПЗК-1

	Ignition_state_decoded: IGNITION_STATE_STRUCT; // Состояние в расшифрованном виде
	Ignition_state: DWORD;                         // Битовая маска состояния
	// bit0  - Запущена процедура розжига запальника
	// bit1  - Нет пламени запальника
	// bit2  - Успешный розжиг запальника
	// bit7  - Погасание пламени запальника
	// bit14 - Повторный розжиг запальника
	// bit15 - Остановка запальника
END_VAR

VAR
	RTC_RESULT: UDINT;
	clock: DWORD;                       // Время ПЛК в секундах

	case_counter: WORD;                 // Счётчик стадий
	time_case_0: DWORD;                 // Время старта стадии
	time_temp: DWORD;                   // Дополнительное время для режима ГАЗ/ИСКРА
	repeat_counter: WORD;               // Счётчик повторов розжига

	start_trig: R_TRIG;                 // Триггер момента старта запальника

	spark_on_impuls: impuls_1_sec;      // Импульс включения искры
	spark_off_impuls: impuls_1_sec;     // Импульс выключения искры
	KZ_on_impuls: impuls_1_sec;         // Импульс открытия клапана запальника
	KZ_off_impuls: impuls_1_sec;        // Импульс закрытия клапана запальника
	PZK_1_on_impuls: impuls_1_sec;      // Импульс открытия ПЗК-1

	ignition_flame_f_trig: F_TRIG;      // Триггер погасания запальника
	ignition_flame_tof: TOF;            // Задержка пропадания пламени запальника

	clear_ton: ARRAY[1..5] OF TON;      // Таймеры сброса сообщений
END_VAR

VAR CONSTANT
	// Индексы настроек
	IDX_MODE              : INT := 1;   // 0-ИСКРА/ГАЗ, 1-ГАЗ/ИСКРА
	IDX_REPEAT            : INT := 2;   // 0-без повтора, 1-с повтором
	IDX_T_IGNITION        : INT := 3;   // Время работы искры
	IDX_T_GAS_SPARK       : INT := 4;   // Задержка между газом и искрой
	IDX_T_FLAME_CHECK     : INT := 5;   // Задержка до контроля пламени

	// Стадии автомата
	ST_IDLE               : WORD := 0;  // Ожидание
	ST_SELECT_MODE        : WORD := 1;  // Выбор режима ГАЗ/ИСКРА или ИСКРА/ГАЗ
	ST_WAIT_GAS_SPARK     : WORD := 2;  // Ожидание t_1 для режима ГАЗ/ИСКРА
	ST_WAIT_IGNITION      : WORD := 3;  // Ожидание t_ignition
	ST_CHECK_FLAME        : WORD := 4;  // Контроль пламени после t_2
	ST_STOP               : WORD := 5;  // Выход / останов
	ST_FINISH             : WORD := 6;  // Завершение процедуры
	ST_WAIT_PZK1          : WORD := 7;  // Ожидание открытия ПЗК-1
END_VAR

// === IMPLEMENTATION ===

// Часы реального времени
clock := SysTimeRTCGet(pResult := RTC_RESULT);

// Обнуление импульсных выходов
spark_on_impuls(CLK := FALSE, Q => spark_on);
spark_off_impuls(CLK := FALSE, Q => spark_off);
KZ_on_impuls(CLK := FALSE, Q => KZ_on);
KZ_off_impuls(CLK := FALSE, Q => KZ_off);
PZK_1_on_impuls(CLK := FALSE, Q => PZK_1_on);

// Определение момента старта запальника
start_trig(CLK := start);

// Задержка пропадания пламени запальника
ignition_flame_tof(
	IN := ignition_flame,
	PT := REAL_TO_TIME(ignition_settings.VALUE[IDX_T_FLAME_CHECK] * 1000)
);

// Определение момента потухания пламени запальника
ignition_flame_f_trig(CLK := ignition_flame_tof.Q);

// Если пламя запальника погасло - закрываем клапан
IF ignition_flame_f_trig.Q THEN
	KZ_off_impuls(CLK := TRUE, Q => KZ_off);
	Ignition_state_decoded.flame_lost := TRUE;
END_IF;

// Команда стоп
IF stop THEN
	case_counter := ST_STOP;
END_IF;

// Старт розжига запальника
IF start_trig.Q AND NOT ignition_flame AND NOT start_block THEN
	Ignition_state_decoded.in_progress := TRUE;
	repeat_counter := 0;

	IF NOT PZK_1_state THEN
		PZK_1_on_impuls(CLK := TRUE, Q => PZK_1_on);
		time_case_0 := clock;
		case_counter := ST_WAIT_PZK1;
	ELSE
		case_counter := ST_SELECT_MODE;
	END_IF
END_IF;


// Автомат стадий
CASE case_counter OF

	ST_SELECT_MODE:
		// Определение режима ГАЗ/ИСКРА или ИСКРА/ГАЗ
		IF ignition_settings.Value[IDX_MODE] = 1 THEN
			// ГАЗ/ИСКРА
			time_temp := REAL_TO_DWORD(ignition_settings.Value[IDX_T_GAS_SPARK]);
			case_counter := ST_WAIT_GAS_SPARK;
		ELSE
			// ИСКРА/ГАЗ
			spark_on_impuls(CLK := TRUE, Q => spark_on);
			time_temp := 0;
			case_counter := ST_WAIT_IGNITION;
		END_IF

		KZ_on_impuls(CLK := TRUE, Q => KZ_on);
		time_case_0 := clock;


	ST_WAIT_GAS_SPARK:
		// Ждём t_1 для режима ГАЗ/ИСКРА
		IF clock - time_case_0 >= REAL_TO_DWORD(ignition_settings.Value[IDX_T_GAS_SPARK]) THEN
			spark_on_impuls(CLK := TRUE, Q => spark_on);
			case_counter := ST_WAIT_IGNITION;
		END_IF


	ST_WAIT_IGNITION:
		// Ждём t_ignition
		IF clock - (time_case_0 + time_temp) >= REAL_TO_DWORD(ignition_settings.Value[IDX_T_IGNITION]) THEN
			spark_off_impuls(CLK := TRUE, Q => spark_off);
			case_counter := ST_CHECK_FLAME;
		END_IF


	ST_CHECK_FLAME:
		// Ждём t_2 и затем контролируем пламя
		IF clock - (time_case_0 + time_temp + REAL_TO_DWORD(ignition_settings.Value[IDX_T_IGNITION])) >= REAL_TO_DWORD(ignition_settings.Value[IDX_T_FLAME_CHECK]) THEN
			IF ignition_flame THEN
				// Успешный розжиг
				Ignition_state_decoded.success_msg := TRUE;
				case_counter := ST_FINISH;
			ELSE
				// Неуспешный розжиг
				IF ignition_settings.Value[IDX_REPEAT] = 1 AND repeat_counter < 1 THEN
					case_counter := ST_SELECT_MODE;
					Ignition_state_decoded.repeat_msg := TRUE;
					repeat_counter := repeat_counter + 1;
				ELSE
					Ignition_state_decoded.no_flame := TRUE;
					case_counter := ST_STOP;
				END_IF
			END_IF
		END_IF


	ST_STOP:
		// Выход / останов
		Ignition_state_decoded.stop_msg := TRUE;
		KZ_off_impuls(CLK := TRUE, Q => KZ_off);
		case_counter := ST_FINISH;


	ST_FINISH:
		// Завершение процедуры
		Ignition_state_decoded.in_progress := FALSE;
		Ignition_state_decoded.repeat_msg := FALSE;
		spark_off_impuls(CLK := TRUE, Q => spark_off);
		case_counter := ST_IDLE;


	ST_WAIT_PZK1:
		// Ожидание ПЗК-1 перед запуском алгоритма
		IF PZK_1_state THEN
			case_counter := ST_SELECT_MODE;
		ELSIF time_wait(time_case_0, 60) THEN
			case_counter := ST_SELECT_MODE;
		END_IF

END_CASE;


// Таймеры автосброса сообщений
clear_ton[1](IN := Ignition_state_decoded.no_flame,    PT := T#1S);
clear_ton[2](IN := Ignition_state_decoded.success_msg, PT := T#1S);
clear_ton[3](IN := Ignition_state_decoded.flame_lost,  PT := T#1S);
clear_ton[4](IN := Ignition_state_decoded.repeat_msg,  PT := T#1S);
clear_ton[5](IN := Ignition_state_decoded.stop_msg,    PT := T#1S);

// Автосброс сообщений
IF clear_ton[1].Q THEN Ignition_state_decoded.no_flame := FALSE; END_IF
IF clear_ton[2].Q THEN Ignition_state_decoded.success_msg := FALSE; END_IF
IF clear_ton[3].Q THEN Ignition_state_decoded.flame_lost := FALSE; END_IF
IF clear_ton[4].Q THEN Ignition_state_decoded.repeat_msg := FALSE; END_IF
IF clear_ton[5].Q THEN Ignition_state_decoded.stop_msg := FALSE; END_IF


// Формирование DWORD из структуры
Ignition_state := 0;
Ignition_state.0 := Ignition_state_decoded.in_progress;
Ignition_state.1 := Ignition_state_decoded.no_flame;
Ignition_state.2 := Ignition_state_decoded.success_msg;
Ignition_state.3 := Ignition_state_decoded.reserved_3;
Ignition_state.4 := Ignition_state_decoded.reserved_4;
Ignition_state.5 := Ignition_state_decoded.reserved_5;
Ignition_state.6 := Ignition_state_decoded.reserved_6;
Ignition_state.7 := Ignition_state_decoded.flame_lost;
Ignition_state.8 := Ignition_state_decoded.reserved_8;
Ignition_state.9 := Ignition_state_decoded.reserved_9;
Ignition_state.10 := Ignition_state_decoded.reserved_10;
Ignition_state.11 := Ignition_state_decoded.reserved_11;
Ignition_state.12 := Ignition_state_decoded.reserved_12;
Ignition_state.13 := Ignition_state_decoded.reserved_13;
Ignition_state.14 := Ignition_state_decoded.repeat_msg;
Ignition_state.15 := Ignition_state_decoded.stop_msg;
Ignition_state.16 := Ignition_state_decoded.reserved_16;
Ignition_state.17 := Ignition_state_decoded.reserved_17;