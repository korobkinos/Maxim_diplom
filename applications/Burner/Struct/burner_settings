TYPE burner_settings :
STRUCT
	VALUE: ARRAY[1..10] OF REAL := [50,3,1,0,3,20,0,0,0,0];
	// 1  - Время ожидания открытия ПЗК-1, сек
	// 2  - Время задержки открытия ШВ относительно ГЗ, сек
	// 3  - Режим открытия ГЗ и ШВ:
	//      0 = открыть
	//      1 = в автомат (выход на минимальную мощность)
	// 4  - Положение ШВ при останове горелки:
	//      0 = закрыть
	//      1 = оставить в текущем положении
	// 5  - Время ожидания появления пламени горелки после открытия ПЗК-2, сек
	// 6  - Время ожидания готовности запальника, сек
	// 7  - резерв
	// 8  - резерв
	// 9  - резерв
	// 10 - резерв
END_STRUCT
END_TYPE