	PID_quantity	: WORD:=10;			//кол-во регуляторов на горелке	

	//массив настроек
	SP				: WORD:=1;			//1-Задание для регулятора
	noise			: WORD:=2;			//2-Зона нечувствительности
	Kp				: WORD:=3;			//3-Коэффициент пропорциональности
