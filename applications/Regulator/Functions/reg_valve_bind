FUNCTION reg_valve_bind : BOOL
VAR CONSTANT
	pid_bind_enabled: WORD:= 0;
	pid_bind: WORD:= 1;
	valve_bind: WORD:= 2;
	pv_bind: WORD:= 3;
	proc_bind : WORD:= 4;	
	(*
	1-PID_SENSOR//Датчик регулятора
	5-PID_PROC //Указатель положения
	*)
	pid_sensor: WORD:= 1;
	pid_proc : WORD:= 5; 
END_VAR
VAR_INPUT
	map : ARRAY[0..PID_quantity] OF ARRAY[0..4] OF WORD; //0-№регулятора; 1-№задвижки
END_VAR
VAR_IN_OUT
	ai_in_scale : ARRAY[0..in_out_quantity]	OF REAL;
	pid_control: ARRAY[0..PID_quantity] OF PID_CONTROL;
	value_control: ARRAY[0..counter_armature] OF PID_CONTROL;	
END_VAR
VAR
    i: WORD;
    pid_idx: WORD;
    valve_idx: WORD;
	pv_idx: WORD;
	proc_idx: WORD;
END_VAR

// === IMPLEMENTATION ===

FOR i:= 0 TO PID_quantity DO    
	IF map[i][pid_bind_enabled] <> 0 THEN					
		pid_idx := map[i][pid_bind];
		valve_idx := map[i][valve_bind];
		pv_idx := map[i][pv_bind];
		proc_idx:= map[i][proc_bind];
		
		// Копируем поля управления из pid_control в value_control
		value_control[valve_idx].man_up := pid_control[pid_idx].man_up;
		value_control[valve_idx].man_down := pid_control[pid_idx].man_down;
		value_control[valve_idx].man_set := pid_control[pid_idx].man_set;
		value_control[valve_idx].auto_set := pid_control[pid_idx].auto_set;
		value_control[valve_idx].up_out := pid_control[pid_idx].up_out;
		value_control[valve_idx].down_out := pid_control[pid_idx].down_out;
		value_control[valve_idx].trend := pid_control[pid_idx].trend;
		
		// Копируем состояния датчиков из value_control в pid_control
		pid_control[pid_idx].open_state := value_control[valve_idx].open_state;
		pid_control[pid_idx].closed_state := value_control[valve_idx].closed_state;
		
		//привязанные аналоги для регулятора (PV, %)
		pid_control[pid_idx].trend.DATA[pid_sensor]:=  ai_in_scale[pv_idx]; //PV
		pid_control[pid_idx].trend.DATA[pid_proc]:=  ai_in_scale[proc_idx]; //%
    END_IF
END_FOR