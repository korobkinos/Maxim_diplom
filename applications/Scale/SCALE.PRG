PROGRAM SCALE
VAR
	i: WORD;
	scale: ai_scale;
END_VAR

// === IMPLEMENTATION ===

//включение имитации аналогов
ai_imitation_bind(
	enable:= GVL_VALVE.imitation_mode,
	map_bind:= SETTINGS.map_valve_ai_bind,
	percent_imitation:= GVL_VALVE.percent_imitation,
	ai_in:= GVL_SCALE.AI_IN_RAW,		
	);
//обработка сигналов 
scale(
	in:= GVL_SCALE.AI_IN_RAW,
	ch_err:= GVL_SCALE.AI_IN_ERR,
	settings:= SETTINGS.SENSOR_AI_SETTINGS,
	out_r => GVL_SCALE.AI_IN_SCALE,
	warning_min => GVL_SCALE.AI_IN_WARN_MIN,
	warning_max => GVL_SCALE.AI_IN_WARN_MAX,
	alarm_min => GVL_SCALE.AI_IN_ALARM_MIN,
	alarm_max => GVL_SCALE.AI_IN_ALARM_MAX
	
	);