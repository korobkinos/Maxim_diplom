FUNCTION scale_singl : REAL
VAR_INPUT
    IN: REAL;
    XMIN: REAL;
    XMAX: REAL;
    YMIN: REAL;
    YMAX: REAL;
END_VAR
VAR
    Sensor_Range: REAL;
    Out_Range: REAL;
END_VAR

// === IMPLEMENTATION ===

// Определение диапазонов входного и выходного значений
Sensor_Range := XMAX - XMIN;
Out_Range := YMAX - YMIN;

IF Sensor_Range <> 0 THEN
    scale_singl := ((IN - XMIN) / Sensor_Range) * Out_Range + YMIN;
END_IF

// Ограничение пределов min/max
IF YMIN < YMAX THEN
    // Если диапазон положительный
    IF scale_singl < YMIN THEN
        scale_singl := YMIN;
    END_IF;
    IF scale_singl > YMAX THEN
        scale_singl := YMAX;
    END_IF;
ELSE
    // Если диапазон отрицательный
    IF scale_singl > YMIN THEN
        scale_singl := YMIN;
    END_IF;
    IF scale_singl < YMAX THEN
        scale_singl := YMAX;
    END_IF;
END_IF