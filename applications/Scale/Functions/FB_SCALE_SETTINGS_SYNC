FUNCTION_BLOCK FB_SCALE_SETTINGS_SYNC
VAR
	ch_idx : WORD;
	item_idx : WORD;
	flat_idx : WORD;
	load_requested : BOOL;
	save_requested : BOOL;
	init_done : BOOL;
END_VAR

VAR CONSTANT
	scale_value_min_index : WORD := 0;
	scale_value_max_index : WORD := 10;
END_VAR

// === IMPLEMENTATION ===

IF NOT init_done THEN
	FOR ch_idx := 1 TO in_out_quantity DO
		FOR item_idx := scale_value_min_index TO scale_value_max_index DO
			flat_idx := GetGroupedFlatIndex(
				group_idx := ch_idx,
				item_idx := item_idx,
				item_count := ai_scale_hmi_quantity,
				item_base := 0
			);

			IF (flat_idx >= 1) AND (flat_idx <= in_out_quantity * ai_scale_hmi_quantity) THEN
				GVL_SCALE_HMI.hmi_ai_scale_flat[flat_idx] := SETTINGS.ai_scale_settings[ch_idx].VALUE[item_idx];
			END_IF;
		END_FOR;
	END_FOR;

	init_done := TRUE;
END_IF;

load_requested := GVL_SCALE_HMI.hmi_load_settings;
save_requested := GVL_SCALE_HMI.hmi_save_settings;

IF load_requested THEN
	FOR ch_idx := 1 TO in_out_quantity DO
		FOR item_idx := scale_value_min_index TO scale_value_max_index DO
			flat_idx := GetGroupedFlatIndex(
				group_idx := ch_idx,
				item_idx := item_idx,
				item_count := ai_scale_hmi_quantity,
				item_base := 0
			);

			IF (flat_idx >= 1) AND (flat_idx <= in_out_quantity * ai_scale_hmi_quantity) THEN
				GVL_SCALE_HMI.hmi_ai_scale_flat[flat_idx] := SETTINGS.ai_scale_settings[ch_idx].VALUE[item_idx];
			END_IF;
		END_FOR;
	END_FOR;

	GVL_SCALE_HMI.hmi_load_settings := FALSE;
ELSIF save_requested THEN
	FOR ch_idx := 1 TO in_out_quantity DO
		FOR item_idx := scale_value_min_index TO scale_value_max_index DO
			flat_idx := GetGroupedFlatIndex(
				group_idx := ch_idx,
				item_idx := item_idx,
				item_count := ai_scale_hmi_quantity,
				item_base := 0
			);

			IF (flat_idx >= 1) AND (flat_idx <= in_out_quantity * ai_scale_hmi_quantity) THEN
				SETTINGS.ai_scale_settings[ch_idx].VALUE[item_idx] := GVL_SCALE_HMI.hmi_ai_scale_flat[flat_idx];
			END_IF;
		END_FOR;
	END_FOR;

	GVL_SCALE_HMI.hmi_save_settings := FALSE;
END_IF;
