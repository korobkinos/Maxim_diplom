{attribute 'global_init_slot' := '400'}
VAR_GLOBAL CONSTANT
	
	burner_quantity							:		WORD:=4; (* Количество горелок в проекте *)
	burner_valve_quantity					:		WORD:=32; (* Количество позиций арматуры на горелку при локальной индексации 0..31 *)
	total_burner_valve_quantity				:		WORD:=32; (* Общее количество позиций арматуры: burner_quantity * burner_valve_quantity *)	
	total_burner_armature_quantity			:		WORD:=32; (* Общее количество настроек арматуры: burner_quantity * (counter_armature + 1) *)	
	armature_time_hmi_item_quantity			:		WORD:=3; (* Количество HMI-полей времени на одну позицию арматуры: wait_time, pull_time, off_time *)	
	total_burner_armature_time_hmi_quantity	:		WORD:=96; (* Общее количество HMI-полей времени арматуры: total_burner_armature_quantity * armature_time_hmi_item_quantity*)
	burner_protect_quantity					:		WORD:=15; (* Количество локальных защит на горелку при индексации 0..15 *)
	total_burner_protect_quantity			:		WORD:=16; (* Общее количество настроек защит: burner_quantity * (burner_protect_quantity + 1)*)
	protect_delay_hmi_item_quantity			:		WORD:=19; (* Количество HMI-полей задержек защит на горелку: (burner_protect_quantity + 1) + 3 *)
	total_burner_protect_delay_hmi_quantity	:		WORD:=19; (* Общее количество HMI-полей задержек защит: burner_quantity * protect_delay_hmi_item_quantity*)	
	regulator_per_burner					:		WORD:=11; (* Количество регуляторов на горелку при локальной индексации 0..PID_quantity *)	
	total_burner_regulator_quantity			:		WORD:=11; (* Общее количество регуляторов: burner_quantity * regulator_per_burner*)	
	pid_settings_quantity					:		WORD:=15; (* Количество параметров PID_SETTINGS.VALUE *)	
	total_burner_pid_settings_quantity		:		WORD:=165; (* Общее количество параметров PID для всех регуляторов: total_burner_regulator_quantity * pid_settings_quantity*)
	gas_air_map_quantity					:		WORD:=30; (* Количество элементов газовоздушной карты на горелку: 10 GAS + 10 AIR + 10 SHIBER *)
	total_burner_gas_air_map_quantity		:		WORD:=30; (* Общее количество элементов газовоздушной карты: burner_quantity * gas_air_map_quantity *)
	burner_reg_binding_item_quantity		:		WORD:=5; (* Количество полей в одной записи привязки регулятора: enabled, pid_idx, valve_idx, pv_idx, proc_idx *)	
	total_burner_reg_binding_quantity		:		WORD:=55; (* Общее количество полей карты привязки: total_burner_regulator_quantity * burner_reg_binding_item_quantity*)
	
	pressure_per_burner						:		WORD:=1; (* Количество контуров опрессовки на горелку *)	
	total_burner_pressure_quantity			:		WORD:=1; (* Общее количество контуров опрессовки: burner_quantity * pressure_per_burner*)	
	pressure_hmi_item_quantity				:		WORD:=9; (* Количество HMI-полей pressure_settings.VALUE на горелку *)	
	total_pressure_hmi_quantity				:		WORD:=9; (* Общее количество HMI-полей опрессовки: burner_quantity * pressure_hmi_item_quantity *)	
	ignition_per_burner						:		WORD:=1; (* Количество контуров розжига на горелку *)	
	total_burner_ignition_quantity			:		WORD:=1; (* Общее количество контуров розжига: burner_quantity * ignition_per_burner*)	
	ignition_hmi_item_quantity				:		WORD:=5; (* Количество HMI-полей ignition_settings.VALUE на горелку *)	
	total_ignition_hmi_quantity				:		WORD:=5; (* Общее количество HMI-полей розжига: burner_quantity * ignition_hmi_item_quantity *)

	
	in_out_quantity							:		WORD:=16; (* Количество физических аналоговых сигналов в системе *)	
	ai_scale_hmi_item_quantity				:		WORD:=11; (* Количество элементов SCALE_DATA.VALUE на один AI-канал *)	
	total_ai_scale_hmi_quantity				:		WORD:=176; (* Общее количество HMI-полей scale-настроек: in_out_quantity * ai_scale_hmi_item_quantity*)
END_VAR