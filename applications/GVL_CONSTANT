{attribute 'global_init_slot' := '400'}
VAR_GLOBAL CONSTANT
	burner_quantity                     : WORD := 4;   (* burners count *)
	burner_valve_quantity               : WORD := 32;  (* valves per burner, local index 0..31 *)
	total_burner_armature_quantity      : WORD := burner_quantity * burner_valve_quantity;
	armature_time_hmi_item_quantity     : WORD := 3;   (* wait/pull/off fields per valve *)

	burner_protect_quantity             : WORD := 16;  (* protects per burner, local index 0..15 *)
	protect_delay_hmi_item_quantity     : WORD := 19;  (* 16 protect delays + 3 common delays *)

	burner_regulator_quantity           : WORD := 11;  (* regulators per burner, local index 0..PID_quantity *)
	pid_settings_quantity               : WORD := 15;
	gas_air_map_quantity                : WORD := 30;
	burner_reg_binding_item_quantity    : WORD := 5;
	reg_binding_off                     : WORD := 0;
	reg_binding_on                      : WORD := 1;

	pressure_hmi_quantity               : WORD := 9;
	ignition_hmi_quantity               : WORD := 5;

	in_out_quantity                     : WORD := 16;
	ai_scale_hmi_quantity               : WORD := 11;
END_VAR
