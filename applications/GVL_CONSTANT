{attribute 'global_init_slot' := '400'} // для определения порядка инициализации переменных
VAR_GLOBAL CONSTANT
	(*
	Архитектурные константы для будущей миграции на несколько горелок:
	- горелки индексируются как 1..burner_quantity;
	- массивы для визуализации/интеграции должны быть плоскими;
	- Weintek/OPC UA не должны опираться на вложенные массивы.
	*)
	burner_quantity							:		WORD:=1;			//Текущее количество горелок (пока один экземпляр)
	burner_valve_quantity					:		WORD:=32;			//32 позиции арматуры на горелку (текущая локальная индексация 0..31)
	total_burner_valve_quantity				:		WORD:=burner_quantity*burner_valve_quantity; //Плоский размер массива арматуры для всех горелок
	total_burner_armature_quantity			:		WORD:=burner_quantity*(counter_armature+1); //Плоский размер массива имитации арматуры для всех горелок

	burner_protect_quantity					:		WORD:=15;			//Количество горелочных защит
	total_burner_protect_quantity			:		WORD:=burner_quantity*(burner_protect_quantity+1); //Плоский размер массива защит для всех горелок

	regulator_per_burner					:		WORD:=PID_quantity+1; //Количество регуляторов на горелку (локальная индексация 0..PID_quantity)
	total_burner_regulator_quantity			:		WORD:=burner_quantity*regulator_per_burner; //Плоский размер массива регуляторов для всех горелок

	pressure_per_burner						:		WORD:=1;			//Количество контуров опрессовки на горелку
	total_burner_pressure_quantity			:		WORD:=burner_quantity*pressure_per_burner; //Плоский размер массива опрессовки для всех горелок
	ignition_per_burner						:		WORD:=1;			//Количество контуров розжига на горелку
	total_burner_ignition_quantity			:		WORD:=burner_quantity*ignition_per_burner; //Плоский размер массива розжига для всех горелок

	(*
	Пояснение по области миграции:
	- функции индексации переводят локальные индексы горелки в плоский глобальный индекс;
	- текущие локальные индексы арматуры остаются 0-базными, возможный переход на 1-базные выполняется позже;
	- вентиляция остается логикой уровня котла и не переносится в FB_BURNER_UNIT;
	- логика AutoBurner (авторозжиг и общая автоматическая цепочка) исключена из миграции в FB_BURNER_UNIT.
	*)

	in_out_quantity							:		WORD:=16;			//кол-во физических аналоговых сигналов в системе
	//ai_quantity								:	WORD:=12; //всего AI в системе	
END_VAR
