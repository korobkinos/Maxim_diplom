PROGRAM IGNITION
VAR	
	ignition_control: ignition_singl;
	fp: ARRAY[0..31] OF R_TRIG;
	fn: ARRAY[0..31] OF F_TRIG;
END_VAR

// === IMPLEMENTATION ===

ignition_control(
	start := GVL_IGNITION.start OR GVL_BURNER.Ignition_SET,
	start_block := GVL_IGNITION.start_block OR GVL_IGNITION.ignition_block,
	stop := GVL_IGNITION.stop OR GVL_BURNER.Ignition_RESET,
	ignition_flame := GVL_IGNITION.ignition_flame,// OR GVL_SIMULATION.ignition_ignit_open,
	PZK_1_state := GVL_VALVE.open_state[pzk_1],

	spark_on => GVL_IGNITION.spark_SET,
	spark_off => GVL_IGNITION.spark_RESET,
	KZ_on => GVL_IGNITION.KZ_SET,
	KZ_off => GVL_IGNITION.KZ_RESET,
	PZK_1_on => GVL_IGNITION.PZK_1_SET,
	
	Ignition_state_decoded => GVL_IGNITION.Ignition_state_decoded,
	Ignition_state => GVL_IGNITION.Ignition_state,

	ignition_settings := SETTINGS.ignition_settings
);

IF SETTINGS.armature_simulation THEN	
	//в режиме имитации когда даём команду на подачу искры - имитируем пламя запальника (даём команду на откр. объект "запальник"
	GVL_SIMULATION.ignition_ignit_open S= GVL_VALVE.open_state[kz] AND GVL_VALVE.open_state[spark];
	
	//когда закрыт КЗ, то и пламя тоже гаснет
	GVL_SIMULATION.ignition_ignit_open R= GVL_VALVE.closed_state[kz];
	GVL_SIMULATION.ignition_ignit_closed:= GVL_VALVE.closed_state[kz];
END_IF