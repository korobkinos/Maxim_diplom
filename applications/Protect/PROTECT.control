// ============================================================
// Защита: погасание запальника
// ============================================================

// Постановка на контроль:
// при открытых ПЗК-1 и КЗ, если котёл находится в процессе розжига
IF GVL_VALVE.open_state[pzk_1]
   AND GVL_VALVE.open_state[kz]
   AND GVL_BURNER.boiler_in_process THEN
	protect[PROTECT_CONSTANT.ignition_p].control := TRUE;
END_IF

// Снятие с контроля:
// при вводе защиты по пламени или при закрытии ПЗК-2
IF protect[PROTECT_CONSTANT.pilot_p].control
   OR ft[pzk_2].Q THEN
	protect[PROTECT_CONSTANT.ignition_p].control := FALSE;
END_IF


// ============================================================
// Защита: понижение давления воздуха перед горелкой
// ============================================================

// Задержка ввода защиты
p_air_control_delay_ton(
	IN := GVL_BURNER.boiler_run,
	PT := REAL_TO_TIME(SETTINGS.p_air_control_delay) * 1000
);

// Постановка на контроль:
// после выхода горелки в работу и выдержки времени
IF p_air_control_delay_ton.Q THEN
	protect[PROTECT_CONSTANT.air_burner_p].control := TRUE;
END_IF

// Снятие с контроля:
// при команде на закрытие ПЗК-2 или по сигналу "ПЗК-2 закрыт"
IF ft[pzk_2].Q
   OR GVL_VALVE.closed_state[pzk_2] THEN
	protect[PROTECT_CONSTANT.air_burner_p].control := FALSE;
END_IF


// ============================================================
// Защита: понижение / повышение давления газа перед горелкой
// ============================================================

// Задержка ввода защиты
p_gas_control_delay_ton(
	IN := GVL_BURNER.boiler_run,
	PT := REAL_TO_TIME(SETTINGS.p_gas_control_delay) * 1000
);

// Постановка на контроль:
// после выхода горелки в работу и выдержки времени
IF p_gas_control_delay_ton.Q THEN
	protect[PROTECT_CONSTANT.gas_burner_p].control := TRUE;
	protect[PROTECT_CONSTANT.gas_burner_up_p].control := TRUE;
END_IF

// Снятие с контроля:
// при команде на закрытие ПЗК-2 или по сигналу "ПЗК-2 закрыт"
IF ft[pzk_2].Q
   OR GVL_VALVE.closed_state[pzk_2] THEN
	protect[PROTECT_CONSTANT.gas_burner_p].control := FALSE;
	protect[PROTECT_CONSTANT.gas_burner_up_p].control := FALSE;
END_IF


// ============================================================
// Защита: погасание факела
// ============================================================

// Задержка ввода защиты
flame_control_delay_ton(
	IN := GVL_BURNER.boiler_in_process OR GVL_BURNER.boiler_run,
	PT := REAL_TO_TIME(SETTINGS.flame_control_delay) * 1000
);

// Постановка на контроль:
// по команде открытия ПЗК-2 после выдержки времени
IF GVL_VALVE.control_out[pzk_2]
   AND flame_control_delay_ton.Q THEN
	protect[PROTECT_CONSTANT.pilot_p].control := TRUE;
END_IF

// Снятие с контроля:
// при закрытии ПЗК-2 или при срабатывании защиты по пламени
IF ft[pzk_2].Q
   OR protect[PROTECT_CONSTANT.pilot_p].alarm THEN
	protect[PROTECT_CONSTANT.pilot_p].control := FALSE;
END_IF


// ============================================================
// Защита: самопроизвольное закрытие ПЗК-1
// ============================================================

// Постановка на контроль:
// при работе/розжиге котла и открытом ПЗК-1,
// либо в тестовом режиме
IF ((GVL_BURNER.boiler_in_process OR GVL_BURNER.boiler_run)
    AND GVL_VALVE.open_state[pzk_1])
   OR SETTINGS.test_mode THEN
	protect[PROTECT_CONSTANT.PZK_1_p].control := TRUE;
END_IF

// Снятие с контроля:
// при команде на закрытие ПЗК-1
IF GVL_VALVE.down_out[pzk_1] THEN
	protect[PROTECT_CONSTANT.PZK_1_p].control := FALSE;
END_IF


// ============================================================
// Защита: самопроизвольное закрытие ПЗК-2
// ============================================================

// Постановка на контроль:
// при работе/розжиге котла и открытом ПЗК-2,
// либо в тестовом режиме
IF ((GVL_BURNER.boiler_in_process OR GVL_BURNER.boiler_run)
    AND GVL_VALVE.open_state[pzk_2])
   OR SETTINGS.test_mode THEN
	protect[PROTECT_CONSTANT.PZK_2_p].control := TRUE;
END_IF

// Снятие с контроля:
// при команде на закрытие ПЗК-2
IF GVL_VALVE.down_out[pzk_2] THEN
	protect[PROTECT_CONSTANT.PZK_2_p].control := FALSE;
END_IF


// ============================================================
// Защита: самопроизвольное выключение вентилятора горелки
// ============================================================

// Постановка на контроль:
// при начале процесса розжига котла
IF GVL_VALVE.closed_state[air_shiber] AND GVL_BURNER.boiler_in_process THEN
	protect[PROTECT_CONSTANT.vent_burner_p].control := TRUE;
END_IF

// Снятие с контроля:
// при команде на закрытие или при срабатывании защиты
IF (GVL_BURNER.burner_stop OR GVL_IGNITION_SEQUENCE.stop)
   OR protect[PROTECT_CONSTANT.vent_burner_p].alarm THEN
	protect[PROTECT_CONSTANT.vent_burner_p].control := FALSE;
END_IF